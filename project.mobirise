          "_once": false,
          "_params": {}
        },
        {
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value",
              "& when (@showGradient)": {
                "background-image": "radial-gradient(ellipse farthest-corner at 50% 60%, @gradient 0%, @bg-value 100%)",
                "@media (max-width: 992px)": {
                  "background-image": "radial-gradient(ellipse farthest-corner at 50% 60%, @gradient 0%, @bg-value 110%)"
                }
              }
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".content-wrapper": {
              "margin-bottom": "80px",
              "@media (max-width: 992px)": {
                "margin-bottom": "32px"
              },
              ".mbr-label": {
                "margin-bottom": "32px"
              },
              ".title-wrapper": {
                "margin-bottom": "16px",
                ".mbr-section-title": {
                  "margin-bottom": "0"
                },
                ".mbr-section-subtitle": {
                  "margin-bottom": "0"
                }
              },
              ".text-wrapper": {
                ".mbr-text": {
                  "display": "inline-block",
                  "width": "65%",
                  "margin-bottom": "0",
                  "@media (max-width: 992px)": {
                    "width": "100%"
                  }
                }
              }
            },
            ".items-wrapper": {
              ".item": {
                "margin-bottom": "80px",
                "@media (max-width: 992px)": {
                  "margin-bottom": "16px"
                },
                ".item-wrapper": {
                  "position": "relative",
                  "padding": "64px",
                  "background-color": "@cardBg",
                  "overflow": "hidden",
                  "@media (max-width: 992px)": {
                    "padding": "24px"
                  },
                  ".iconfont-wrapper": {
                    "position": "absolute",
                    "top": "28px",
                    "right": "28px",
                    "width": "20px",
                    "height": "20px",
                    "@media (max-width: 992px)": {
                      "top": "16px",
                      "right": "16px"
                    },
                    ".mbr-iconfont": {
                      "font-size": "18px"
                    }
                  },
                  ".item-img": {
                    "@media (max-width: 992px)": {
                      "margin-bottom": "24px"
                    },
                    "&::before": {
                      "content": "''",
                      "position": "absolute",
                      "right": "-32px",
                      "bottom": "32px",
                      "width": "200px",
                      "height": "200px",
                      "@media (max-width: 992px)": {
                        "bottom": "auto",
                        "top": "-100px",
                        "right": "auto",
                        "left": "-100px"
                      }
                    },
                    "img": {
                      "position": "absolute",
                      "right": "32px",
                      "bottom": "32px",
                      "width": "200px",
                      "height": "200px",
                      "object-fit": "cover",
                      "border-radius": "100% !important",
                      "z-index": "1",
                      "@media (max-width: 992px)": {
                        "position": "static",
                        "margin": "0 auto"
                      }
                    }
                  },
                  ".image_1::before": {
                    "background-image": "radial-gradient(circle closest-side at 50% 50%, @gradient_1 0%, transparent 100%)"
                  },
                  ".image_2": {
                    "img": {
                      "right": "auto",
                      "left": "32px"
                    },
                    "&::before": {
                      "right": "auto",
                      "left": "-32px",
                      "background-image": "radial-gradient(circle closest-side at 50% 50%, @gradient_2 0%, transparent 100%)",
                      "@media (max-width: 992px)": {
                        "bottom": "auto",
                        "top": "-100px",
                        "left": "-100px"
                      }
                    }
                  },
                  ".image_3::before": {
                    "background-image": "radial-gradient(circle closest-side at 50% 50%, @gradient_3 0%, transparent 100%)"
                  },
                  ".card-box": {
                    "padding-right": "250px",
                    "@media (max-width: 1440px)": {
                      "padding-right": "200px"
                    },
                    "@media (max-width: 992px)": {
                      "padding-right": "0"
                    },
                    ".card-title": {
                      "margin-bottom": "32px",
                      "@media (max-width: 992px)": {
                        "margin-bottom": "24px"
                      }
                    },
                    ".card-text": {
                      "margin-bottom": "32px",
                      "@media (max-width: 992px)": {
                        "margin-bottom": "24px"
                      }
                    },
                    ".list-wrapper": {
                      ".list": {
                        "margin": "0",
                        "padding": "0",
                        "list-style-type": "none",
                        "display": "inline-flex",
                        "flex-direction": "column",
                        ".item-wrap": {
                          "position": "relative",
                          "margin-bottom": "20px",
                          "padding-left": "28px",
                          "&::before": {
                            "content": "'✓'",
                            "position": "absolute",
                            "top": "5px",
                            "left": "0",
                            "display": "inline-flex",
                            "align-items": "center",
                            "justify-content": "center",
                            "width": "18px",
                            "height": "18px",
                            "border-radius": "100%",
                            "border": "2px solid @marker",
                            "color": "@marker",
                            "font-size": "11px"
                          },
                          "&:last-child": {
                            "margin-bottom": "0"
                          }
                        }
                      }
                    },
                    ".mbr-section-btn": {
                      "margin-top": "32px",
                      "@media (max-width: 992px)": {
                        "margin-top": "24px"
                      },
                      ".btn": {
                        "margin-bottom": "0"
                      }
                    }
                  }
                },
                ".card_2": {
                  ".card-box": {
                    "padding-right": "0",
                    "padding-left": "250px",
                    "@media (max-width: 1440px)": {
                      "padding-right": "0",
                      "padding-left": "200px"
                    },
                    "@media (max-width: 992px)": {
                      "padding-left": "0"
                    }
                  }
                }
              }
            },
            ".mbr-label": {
              "color": "#4B2A00",
              "text-align": "center"
            },
            ".mbr-section-title": {
              "color": "#111111",
              "text-align": "center"
            },
            ".mbr-section-subtitle": {
              "color": "#6E869B",
