                      },
                      "img": {
                        "width": "200px",
                        "height": "200px",
                        "margin": "0 auto",
                        "object-fit": "cover",
                        "border-radius": "100% !important"
                      }
                    },
                    ".card-box": {
                      "position": "relative",
                      "z-index": "1",
                      ".card-title_1, .card-title_2, .card-title_3, .card-title_4": {
                        "margin-bottom": "16px"
                      },
                      ".card-price_1, .card-price_2, .card-price_3, .card-price_4": {
                        "margin-bottom": "16px"
                      },
                      ".card-text_1, .card-text_2, .card-text_3, .card-text_4": {
                        "margin-bottom": "0"
                      },
                      ".mbr-section-btn": {
                        "width": "100%",
                        "margin-top": "24px",
                        ".btn": {
                          "width": "100%",
                          "justify-content": "space-between",
                          "margin-bottom": "0",
                          "box-shadow": "none !important"
                        }
                      }
                    }
                  },
                  ".card_1": {
                    "background-color": "@cardBg_1",
                    "border-color": "@border_1"
                  },
                  ".card_2": {
                    "background-color": "@cardBg_2",
                    "border-color": "@border_2"
                  },
                  ".card_3": {
                    "background-color": "@cardBg_3",
                    "border-color": "@border_3"
                  }
                }
              }
            },
            ".btn-wrapper": {
              "margin-right": "9%"
            },
            ".mbr-section-title": {
              "color": "#111111",
              "text-align": "center"
            },
            ".mbr-section-subtitle": {
              "color": "#6E869B",
              "text-align": "center"
