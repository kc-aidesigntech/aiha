        {
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".image-wrap": {
              "height": "500px",
              "@media (max-width: 992px)": {
                "height": "350px"
              }
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"image01 strengthm5\" group=\"Image & Video\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\" checked>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/photo-1732568642208-e81e7506a7ce.jpeg\" parallax selected>\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\">\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background3.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#111111\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"image-wrap\"></div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_name": "image01",
          "_sourceTheme": "strengthm5",
          "_cid": "vbylUvtFQm",
          "_anchor": "image-1-vbylUvtFQm",
          "alias": false,
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".card-wrapper": {
              "padding": "64px",
              "background-color": "@containerBg",
              "display": "flex",
              "margin-top": "64px",
              "@media (max-width: 992px)": {
                "display": "block",
                "padding": "24px",
                "margin-top": "0"
              }
            },
            ".image-wrapper": {
              "width": "50%",
              "padding-right": "56px",
              "@media (max-width: 992px)": {
                "padding-right": "0",
                "width": "100%"
              },
              "& when (@reverseContent)": {
                "padding-right": "0",
                "padding-left": "56px",
                "@media (max-width: 992px)": {
                  "padding-left": "0"
                }
              },
              "img": {
                "height": "800px",
                "width": "100%",
                "object-fit": "cover",
                "position": "sticky",
                "top": "132px",
                "margin-top": "-128px",
                "@media (max-width: 1400px)": {
                  "height": "600px"
                },
                "@media (max-width: 992px)": {
                  "height": "350px",
                  "margin": "0 0 32px 0",
                  "position": "static"
                }
              }
            },
            ".content-wrapper": {
              "width": "50%",
              "padding-right": "56px",
              "@media (max-width: 1400px)": {
                "padding-right": "0"
              },
              "@media (max-width: 992px)": {
                "width": "100%"
              },
              "& when (@reverseContent)": {
                "padding-right": "0",
                "padding-left": "56px",
                "@media (max-width: 1400px)": {
                  "padding-left": "0"
                }
              },
              ".content-wrap": {
                "margin-bottom": "80px",
                "@media (max-width: 992px)": {
                  "margin-bottom": "32px"
                },
                ".title-wrapper": {
                  "margin-bottom": "16px",
                  ".mbr-section-title": {
                    "margin-bottom": "0"
                  },
                  ".mbr-section-subtitle": {
                    "margin-bottom": "0"
                  }
                },
                ".text-wrapper": {
                  ".mbr-text": {
                    "display": "inline-block",
                    "width": "90%",
                    "margin-bottom": "0",
                    "@media (max-width: 992px)": {
                      "width": "100%"
                    }
                  }
                }
              },
              ".panel-group": {
                ".card": {
                  "position": "relative",
                  "padding": "24px 24px 24px 32px",
                  "background-color": "@cardBg",
                  "border": "none",
                  "transition": "all 0.3s ease-in-out",
                  "margin-top": "16px",
                  "@media (max-width: 992px)": {
                    "padding": "16px"
                  },
                  "&:first-child": {
                    "margin-top": "0"
                  },
                  ".card-header": {
                    "background-color": "transparent",
                    "border": "none",
                    "border-radius": "0",
                    "padding": "0",
                    ".panel-title": {
                      "display": "flex",
                      "justify-content": "space-between",
                      "align-items": "center",
                      "width": "100%",
                      ".panel-title-edit": {
                        "margin-bottom": "0",
                        "transition": "all 0.3s ease-in-out"
                      },
                      ".icon-wrapper": {
                        "width": "32px",
                        "height": "32px",
                        "min-width": "32px",
                        "display": "inline-flex",
                        "align-items": "center",
                        "justify-content": "center",
                        "margin-left": "24px",
                        "transition": "all 0.3s ease-in-out",
                        "border-radius": "100%",
                        "background-color": "@iconBg",
                        ".mbr-iconfont": {
                          "margin-top": "4px",
                          "font-size": "12px",
                          "transition": "all 0.3s ease-in-out",
                          "color": "@iconColor"
                        },
                        "&:hover": {
                          "background-color": "@activeBg",
                          ".mbr-iconfont": {
                            "color": "@activeColor"
                          }
                        }
                      },
                      "&:not(.collapsed)": {
                        ".icon-wrapper": {
                          "transform": "rotate(180deg)"
                        }
                      }
                    }
                  },
                  ".panel-collapse": {
                    ".panel-body": {
                      "padding-top": "24px",
                      ".panel-text": {
                        "margin-bottom": "0"
                      }
                    }
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#111111"
            },
            ".mbr-section-subtitle": {
              "color": "#6E869B"
            },
            ".mbr-text, .text-wrapper": {
              "color": "#111111"
            },
            ".panel-title-edit": {
              "color": "#111111"
            },
            ".panel-text": {
              "color": "#666666"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"list01 strengthm5\" group=\"List\" plugins=\"mbr-switch-arrow, mobirise-icons2\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"color\" title=\"Container BG\" value=\"#FCFBFA\" name=\"containerBg\" selected>\n        <header>List</header>\n        <select title=\"Amount\" name=\"cardAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\">5</option>\n            <option value=\"6\">6</option>\n            <option value=\"7\" selected>7</option>\n            <option value=\"8\">8</option>\n        </select>\n        <header>Cards</header>\n        <input type=\"color\" title=\"Icon Color\" value=\"#FFFFFF\" name=\"iconColor\" selected>\n        <input type=\"color\" title=\"Icon BG\" value=\"#A47786\" name=\"iconBg\" selected>\n        <input type=\"color\" title=\"Active Color\" value=\"#FFFFFF\" name=\"activeColor\" selected>\n        <input type=\"color\" title=\"Active BG\" value=\"#744B59\" name=\"activeBg\" selected>\n        <input type=\"color\" title=\"BG\" value=\"#ffffff\" name=\"cardBg\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-lg-10\">\n                <div class=\"card-wrapper\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n                    <div class=\"image-wrapper\">\n                        <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/photo-1764641812202-b06c783efd3e.jpeg\" alt=\"Mobirise Website Builder\">\n                    </div>\n                    <div class=\"content-wrapper\">\n                        <div class=\"content-wrap\" mbr-if=\"showTitle || showSubtitle || showText\">\n                            <div class=\"title-wrapper\" mbr-if=\"showTitle || showSubtitle\">\n                                <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                                    <b>Got Questions?</b>\n                                </h2>\n                                <h3 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-2\" mbr-if=\"showSubtitle\">\n                                    <b>Island Answers</b>\n                                </h3>\n                            </div>\n                            <div class=\"text-wrapper\">\n                                <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text, .text-wrapper\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">We&#x27;ve got the lowdown on healthcare here. If you&#x27;re still scratching your head, ask away!</p>\n                            </div>\n                        </div>\n                        <div id=\"bootstrap-accordion\" class=\"panel-group accordionStyles accordion\" role=\"tablist\" aria-multiselectable=\"true\">\n                            <div class=\"card little-radius\">\n                                <div class=\"card-header\" role=\"tab\" id=\"headingOne\">\n                                    <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse1\" aria-expanded=\"false\" aria-controls=\"collapse1\">\n                                        <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">\n                                            <b>How do I sign up?</b>\n                                        </h4>\n                                        <div class=\"icon-wrapper\">\n                                            <span class=\"sign mbr-iconfont mobi-mbri-arrow-down mobi-mbri\"></span>\n                                        </div>\n                                    </a>\n                                </div>\n                                <div id=\"collapse1\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingOne\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                    <div class=\"panel-body\">\n                                        <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Visit our &#x27;Plans&#x27; page or call us. It&#x27;s easier than catching a ferry!</p>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"card little-radius\" mbr-if=\"cardAmount > 1\">\n                                <div class=\"card-header\" role=\"tab\" id=\"headingTwo\">\n                                    <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse2\" aria-expanded=\"false\" aria-controls=\"collapse2\">\n                                        <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">\n                                            <b>What if I&#x27;m not a resident?</b>\n                                        </h4>\n                                        <div class=\"icon-wrapper\">\n                                            <span class=\"sign mbr-iconfont mobi-mbri-arrow-down mobi-mbri\"></span>\n                                        </div>\n                                    </a>\n                                </div>\n                                <div id=\"collapse2\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingTwo\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                    <div class=\"panel-body\">\n                                        <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">We serve everyone who needs care on Anderson Island. Welcome aboard!</p>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"card little-radius\" mbr-if=\"cardAmount > 2\">\n                                <div class=\"card-header\" role=\"tab\" id=\"headingThree\">\n                                    <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse3\" aria-expanded=\"false\" aria-controls=\"collapse3\">\n                                        <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">\n                                            <b>Are services mobile?</b>\n                                        </h4>\n                                        <div class=\"icon-wrapper\">\n                                            <span class=\"sign mbr-iconfont mobi-mbri-arrow-down mobi-mbri\"></span>\n                                        </div>\n                                    </a>\n                                </div>\n                                <div id=\"collapse3\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingThree\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                    <div class=\"panel-body\">\n                                        <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Yes, we&#x27;re building a mobile health hub. Stay tuned for updates!</p>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"card little-radius\" mbr-if=\"cardAmount > 3\">\n                                <div class=\"card-header\" role=\"tab\" id=\"headingFour\">\n                                    <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse4\" aria-expanded=\"false\" aria-controls=\"collapse4\">\n                                        <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">\n                                            <b>Is there financial aid?</b>\n                                        </h4>\n                                        <div class=\"icon-wrapper\">\n                                            <span class=\"sign mbr-iconfont mobi-mbri-arrow-down mobi-mbri\"></span>\n                                        </div>\n                                    </a>\n                                </div>\n                                <div id=\"collapse4\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFour\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                    <div class=\"panel-body\">\n                                        <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">We offer various plans and support options. Let&#x27;s chat about what fits.</p>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"card little-radius\" mbr-if=\"cardAmount > 4\">\n                                <div class=\"card-header\" role=\"tab\" id=\"headingFive\">\n                                    <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse5\" aria-expanded=\"false\" aria-controls=\"collapse5\">\n                                        <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">\n                                            <b>What&#x27;s the travel burden?</b>\n                                        </h4>\n                                        <div class=\"icon-wrapper\">\n                                            <span class=\"sign mbr-iconfont mobi-mbri-arrow-down mobi-mbri\"></span>\n                                        </div>\n                                    </a>\n                                </div>\n                                <div id=\"collapse5\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFive\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                    <div class=\"panel-body\">\n                                        <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">We aim to minimize it! Our goal is care close to home.</p>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"card little-radius\" mbr-if=\"cardAmount > 5\">\n                                <div class=\"card-header\" role=\"tab\" id=\"headingSix\">\n                                    <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse6\" aria-expanded=\"false\" aria-controls=\"collapse6\">\n                                        <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">\n                                            <b>Who runs this place?</b>\n                                        </h4>\n                                        <div class=\"icon-wrapper\">\n                                            <span class=\"sign mbr-iconfont mobi-mbri-arrow-down mobi-mbri\"></span>\n                                        </div>\n                                    </a>\n                                </div>\n                                <div id=\"collapse6\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingSix\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                    <div class=\"panel-body\">\n                                        <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Dedicated islanders committed to your health. We&#x27;re your neighbors!</p>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"card little-radius\" mbr-if=\"cardAmount > 6\">\n                                <div class=\"card-header\" role=\"tab\" id=\"headingSeven\">\n                                    <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse7\" aria-expanded=\"false\" aria-controls=\"collapse7\">\n                                        <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">\n                                            <b>Can I donate?</b>\n                                        </h4>\n                                        <div class=\"icon-wrapper\">\n                                            <span class=\"sign mbr-iconfont mobi-mbri-arrow-down mobi-mbri\"></span>\n                                        </div>\n                                    </a>\n                                </div>\n                                <div id=\"collapse7\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingSeven\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                    <div class=\"panel-body\">\n                                        <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Absolutely! Every bit helps keep care local. See our &#x27;Support&#x27; page.</p>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"card little-radius\" mbr-if=\"cardAmount > 7\">\n                                <div class=\"card-header\" role=\"tab\" id=\"headingEight\">\n                                    <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse8\" aria-expanded=\"false\" aria-controls=\"collapse8\">\n                                        <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">\n                                            <b>Why hire a fitness trainer instead of working out alone?</b>\n                                        </h4>\n                                        <div class=\"icon-wrapper\">\n                                            <span class=\"sign mbr-iconfont mobi-mbri-arrow-down mobi-mbri\"></span>\n                                        </div>\n                                    </a>\n                                </div>\n                                <div id=\"collapse8\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingEight\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                    <div class=\"panel-body\">\n                                        <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                            A trainer ensures you stay motivated, accountable, and safe while maximizing\n                                            results. They provide structure, feedback, and expertise that self-training\n                                            often\n                                            lacks.\n                                        </p>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_name": "list01",
