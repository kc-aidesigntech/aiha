                  "width": "50%",
                  "margin-bottom": "0",
                  "@media (max-width: 992px)": {
                    "width": "100%"
                  }
                }
              }
            },
            ".embla__slide": {
              "display": "flex",
              "justify-content": "center",
              "position": "relative",
              "min-width": "415px",
              "max-width": "415px",
              "@media (max-width: 767px)": {
                "min-width": "100%",
                "max-width": "100%"
              },
              ".slide-content": {
                "width": "100%",
                ".item-wrapper": {
                  "position": "relative",
                  "height": "100%",
                  "padding": "64px 24px 24px 24px",
                  "min-height": "580px",
                  "display": "flex",
                  "flex-direction": "column",
                  "justify-content": "flex-end",
                  "animation": "none !important",
                  "@media (max-width: 992px)": {
                    "min-height": "400px"
                  },
                  ".item-img": {
                    "img": {
                      "position": "absolute",
                      "top": "0",
                      "left": "0",
                      "width": "100%",
                      "height": "100%",
                      "object-fit": "cover"
                    }
                  },
                  ".blur-wrap": {
                    "position": "absolute",
                    "bottom": "0",
                    "left": "0",
                    "width": "100%",
                    "height": "40%",
                    "backdrop-filter": "blur(20px)",
                    "mask-image": "linear-gradient(0deg, #000000 75%, transparent 100%)",
                    "-webkit-mask-image": "linear-gradient(0deg, #000000 75%, transparent 100%)",
                    "pointer-events": "none",
                    "z-index": "1",
                    "@media (max-width: 992px)": {
                      "height": "60%"
                    }
                  },
                  ".card-overlay": {
                    "position": "absolute",
                    "top": "0",
                    "left": "0",
                    "width": "100%",
                    "height": "100%",
                    "background-image": "linear-gradient(0deg, @imageOver 0, transparent 100%)",
                    "opacity": "@imageOpacity",
                    "pointer-events": "none"
                  },
                  ".card-box": {
                    "position": "relative",
                    "z-index": "1",
                    ".card-name": {
                      "margin-bottom": "8px"
                    },
                    ".card-role": {
                      "margin-bottom": "0"
                    },
                    ".card-text": {
                      "margin-top": "16px",
                      "margin-bottom": "0"
                    },
                    ".mbr-section-btn": {
                      "margin-top": "16px",
                      ".btn": {
                        "margin-bottom": "0",
                        "box-shadow": "none !important"
                      }
                    }
                  }
                }
              }
            },
            ".embla__button--next, .embla__button--prev": {
              "display": "flex"
            },
            ".embla__button": {
              "top": "45%",
              "width": "56px",
              "height": "56px",
              "font-size": "16px",
              "background-color": "@arrowsBg !important",
              "color": "@arrowsColor !important",
              "border": "none !important",
              "border-radius": "100%",
              "transition": "all 0.3s",
              "position": "absolute",
              "display": "flex",
              "justify-content": "center",
              "align-items": "center",
              "opacity": "1 !important",
              "& when not (@arrows)": {
                "display": "none"
              },
              "& when not (@arrowsMobile)": {
                "@media (max-width: 768px)": {
                  "display": "none"
                }
              },
              "@media (max-width: 992px)": {
                "top": "0"
              },
              "&:hover": {
                "background-color": "@activeBg !important",
                "color": "@activeColor !important"
              },
              "&:disabled": {
                "background-color": "@arrowsBg !important",
                "color": "@arrowsColor !important",
                "opacity": "0.5 !important"
              },
              "&.embla__button--prev": {
                "left": "32px",
                ".mbr-iconfont": {
                  "margin-right": "4px"
                }
              },
              "&.embla__button--next": {
                "right": "32px",
                ".mbr-iconfont": {
                  "margin-left": "4px"
                }
              }
            },
            ".embla": {
              "position": "relative",
              "width": "100%",
              "display": "flex",
              "justify-content": "center",
              "& when (@arrows)": {
                "@media (max-width: 992px)": {
                  "padding-top": "6rem"
                }
              }
            },
            ".embla__viewport": {
              "overflow": "hidden",
              "width": "100%"
            },
            ".embla__viewport.is-draggable": {
              "cursor": "grab"
            },
            ".embla__viewport.is-dragging": {
              "cursor": "grabbing"
            },
            ".embla__container": {
              "display": "flex",
              "user-select": "none",
              "-webkit-touch-callout": "none",
              "-khtml-user-select": "none",
              "-webkit-tap-highlight-color": "transparent"
            },
            ".item-menu-overlay": {
              "opacity": "0 !important"
            },
            ".mbr-label": {
              "color": "#4B2A00",
              "text-align": "center"
            },
            ".mbr-section-title": {
              "color": "#111111",
              "text-align": "center"
            },
            ".mbr-section-subtitle": {
              "color": "#6E869B",
              "text-align": "center"
            },
            ".mbr-text, .text-wrapper": {
              "color": "#666666",
              "text-align": "center"
            },
            ".card-name": {
              "color": "#ffffff"
            },
            ".card-role": {
              "color": "#ffffff"
            },
            ".card-text": {
              "color": "#ffffff"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"slider01 mbr-embla strengthm5\" group=\"Sliders & Galleries\" plugins=\"embla\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Label\" name=\"showLabel\" checked>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <header>Carousel</header>\n        <input type=\"checkbox\" title=\"Autoplay\" name=\"autoplay\">\n        <input type=\"range\" title=\"Interval\" name=\"interval\" min=\"1\" max=\"10\" value=\"5\" step=\"1\" condition=\"autoplay\">\n        <input type=\"checkbox\" title=\"Loop\" name=\"loop\" checked>\n        <input type=\"checkbox\" title=\"Draggable\" name=\"draggable\" checked>\n        <input type=\"checkbox\" name=\"arrows\" title=\"Arrows\" checked>\n        <input type=\"checkbox\" name=\"arrowsMobile\" title=\"Mobile Arrows\" condition=\"arrows\" checked>\n        <input type=\"color\" title=\"Arrows Color\" value=\"#FFFFFF\" name=\"arrowsColor\" condition=\"arrows\">\n        <input type=\"color\" title=\"Arrows BG\" value=\"#A47786\" name=\"arrowsBg\" condition=\"arrows\">\n        <input type=\"color\" title=\"Active Color\" value=\"#FFFFFF\" name=\"activeColor\" condition=\"arrows\">\n        <input type=\"color\" title=\"Active BG\" value=\"#744B59\" name=\"activeBg\" condition=\"arrows\">\n        <header>Cards</header>\n        <input type=\"range\" name=\"gap\" title=\"Gap\" min=\"0\" max=\"32\" step=\"8\" value=\"8\">\n        <input type=\"checkbox\" title=\"Name\" name=\"showName\" checked>\n        <input type=\"checkbox\" title=\"Role\" name=\"showRole\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showCardText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"color\" title=\"Gradient\" value=\"#111111\" name=\"imageOver\">\n        <input type=\"range\" inline title=\"Gradient Opacity\" name=\"imageOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax required>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Gradient\" name=\"showGradient\" checked condition=\"bg.type == 'color'\">\n        <input type=\"color\" title=\"Gradient Color\" value=\"#FCFBFA\" name=\"gradient\" condition=\"showGradient && bg.type == 'color'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#f4f4f4\" condition=\"overlay && bg.type == 'image'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type == 'image'\">\n    </mbr-parameters>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\" class=\"content-wrap\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"content-wrapper\" mbr-if=\"showLabel || showTitle || showSubtitle || showText\">\n                    <p class=\"mbr-label mbr-fonts-style\" data-app-selector=\".mbr-label\" mbr-theme-style=\"display-7\" mbr-if=\"showLabel\">\n                        <b>Our Team</b>\n                    </p>\n                    <div class=\"title-wrapper\" mbr-if=\"showTitle || showSubtitle\">\n                        <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                            <b>Island Heroes</b>\n                        </h2>\n                        <h3 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-2\" mbr-if=\"showSubtitle\">\n                            <b>Meet Your Caregivers</b>\n                        </h3>\n                    </div>\n                    <div class=\"text-wrapper\">\n                        <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text, .text-wrapper\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">These folks are the backbone of Anderson Island Health. They&#x27;re here to keep you healthy and happy, no matter what.</p>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12\">\n                <div class=\"embla\" data-loop=\"{{loop}}\" data-auto-play=\"{{autoplay}}\" data-auto-play-interval=\"{{interval}}\" data-draggable=\"{{draggable}}\" data-skip-snaps=\"true\" data-align=\"center\" data-contain-scroll=\"trimSnaps\">\n                    <div class=\"embla__viewport\">\n                        <div class=\"embla__container\">\n                            <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper little-radius\">\n                                        <div class=\"item-img\">\n                                            <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/photo-1676385901160-a86dc9ccdfe1.jpeg\" alt=\"Mobirise Website Builder\">\n                                        </div>\n                                        <div class=\"card-overlay little-radius\"></div>\n                                        <div class=\"blur-wrap little-radius\"></div>\n                                        <div class=\"card-box\">\n                                            <h4 class=\"card-name mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-name\" mbr-if=\"showName\">\n                                                <b>Dr. Anya Sharma</b>\n                                            </h4>\n                                            <p class=\"card-role mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-role\" mbr-if=\"showRole\">Lead Physician</p>\n                                            <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text, .mbr-section-btn\" mbr-if=\"showCardText\">Passionate about island wellness. Knows everyone&#x27;s name!</p>\n                                            <div mbr-buttons=\"\" mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                                <a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                                    <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                                                    Contact Now\n                                                </a>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper little-radius\">\n                                        <div class=\"item-img\">\n                                            <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/photo-1509098681029-b45e9c845022.jpeg\" alt=\"Mobirise Website Builder\">\n                                        </div>\n                                        <div class=\"card-overlay little-radius\"></div>\n                                        <div class=\"blur-wrap little-radius\"></div>\n                                        <div class=\"card-box\">\n                                            <h4 class=\"card-name mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-name\" mbr-if=\"showName\">\n                                                <b>Ben Carter</b>\n                                            </h4>\n                                            <p class=\"card-role mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-role\" mbr-if=\"showRole\">Community Nurse</p>\n                                            <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text, .mbr-section-btn\" mbr-if=\"showCardText\">Always ready with a smile and a bandage. Your friendly neighborhood nurse.</p>\n                                            <div mbr-buttons=\"\" mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                                <a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                                    <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                                                    Contact Now\n                                                </a>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper little-radius\">\n                                        <div class=\"item-img\">\n                                            <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/photo-1564972379941-fde999e14945.jpeg\" alt=\"Mobirise Website Builder\">\n                                        </div>\n                                        <div class=\"card-overlay little-radius\"></div>\n                                        <div class=\"blur-wrap little-radius\"></div>\n                                        <div class=\"card-box\">\n                                            <h4 class=\"card-name mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-name\" mbr-if=\"showName\">\n                                                <b>Maria Rodriguez</b>\n                                            </h4>\n                                            <p class=\"card-role mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-role\" mbr-if=\"showRole\">Health Navigator</p>\n                                            <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text, .mbr-section-btn\" mbr-if=\"showCardText\">Helps you find the right plan and resources. Makes healthcare simple.</p>\n                                            <div mbr-buttons=\"\" mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                                <a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                                    <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                                                    Contact Now\n                                                </a>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper little-radius\">\n                                        <div class=\"item-img\">\n                                            <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/photo-1535026406642-530e01750ad7.jpeg\" alt=\"Mobirise Website Builder\">\n                                        </div>\n                                        <div class=\"card-overlay little-radius\"></div>\n                                        <div class=\"blur-wrap little-radius\"></div>\n                                        <div class=\"card-box\">\n                                            <h4 class=\"card-name mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-name\" mbr-if=\"showName\">\n                                                <b>Sam Lee</b>\n                                            </h4>\n                                            <p class=\"card-role mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-role\" mbr-if=\"showRole\">Operations Manager</p>\n                                            <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text, .mbr-section-btn\" mbr-if=\"showCardText\">Keeps the lights on and the services running smoothly. The real MVP.</p>\n                                            <div mbr-buttons=\"\" mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                                <a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                                    <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                                                    Contact Now\n                                                </a>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper little-radius\">\n                                        <div class=\"item-img\">\n                                            <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/photo-1636624498233-0c3c5ab4186e.jpeg\" alt=\"Mobirise Website Builder\">\n                                        </div>\n                                        <div class=\"card-overlay little-radius\"></div>\n                                        <div class=\"blur-wrap little-radius\"></div>\n                                        <div class=\"card-box\">\n                                            <h4 class=\"card-name mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-name\" mbr-if=\"showName\">\n                                                <b>Chloe Davis</b>\n                                            </h4>\n                                            <p class=\"card-role mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-role\" mbr-if=\"showRole\">Wellness Coach</p>\n                                            <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text, .mbr-section-btn\" mbr-if=\"showCardText\">Inspires healthy habits. Your personal cheerleader for a better you.</p>\n                                            <div mbr-buttons=\"\" mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                                <a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                                    <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                                                    Contact Now\n                                                </a>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <button class=\"embla__button embla__button--prev\">\n                        <span class=\"mobi-mbri mobi-mbri-arrow-prev mbr-iconfont\" aria-hidden=\"true\"></span>\n                        <span class=\"sr-only visually-hidden visually-hidden visually-hidden visually-hidden visually-hidden\">Previous</span>\n                    </button>\n                    <button class=\"embla__button embla__button--next\">\n                        <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont\" aria-hidden=\"true\"></span>\n                        <span class=\"sr-only visually-hidden visually-hidden visually-hidden visually-hidden visually-hidden\">Next</span>\n                    </button>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_name": "slider01",
          "_sourceTheme": "strengthm5",
          "_cid": "vbylUvIHUA",
          "_anchor": "team-1-vbylUvIHUA",
          "alias": false,
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value",
              "& when (@showGradient)": {
                "background-image": "linear-gradient(0deg, @gradient -70%, @bg-value 100%)"
              }
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".content-wrapper": {
              "margin-bottom": "80px",
              "@media (max-width: 992px)": {
                "margin-bottom": "32px"
              },
              ".mbr-label": {
                "margin-bottom": "32px"
              },
              ".title-wrapper": {
                "margin-bottom": "16px",
                ".mbr-section-title": {
                  "margin-bottom": "0"
                },
                ".mbr-section-subtitle": {
                  "margin-bottom": "0"
                }
              },
              ".text-wrapper": {
                ".mbr-text": {
                  "display": "inline-block",
                  "width": "65%",
                  "margin-bottom": "0",
                  "@media (max-width: 992px)": {
                    "width": "100%"
                  }
                }
              }
            },
            ".google-map": {
              "iframe": {
                "height": "600px",
                "filter": "hue-rotate(45deg)",
                "@media (max-width: 992px)": {
                  "height": "350px"
                }
              }
            },
            ".mbr-label": {
              "color": "#4B2A00",
              "text-align": "center"
            },
            ".mbr-section-title": {
              "color": "#111111",
              "text-align": "center"
            },
            ".mbr-section-subtitle": {
              "color": "#6E869B",
              "text-align": "center"
            },
            ".mbr-text, .text-wrapper": {
              "color": "#666666",
              "text-align": "center"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"map01 strengthm5\" group=\"Contact\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Label\" name=\"showLabel\" checked>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <header>Map</header>\n        <input type=\"map\" title=\"Map\" name=\"googleMap\" value=\"<iframe src=&quot;https://www.google.com/maps/embed/v1/place?key&#x3D;AIzaSyCt1265A4qvZy9HKUeA8J15AOC4SrCyZe4&amp;q&#x3D;Anderson%20Island&quot;></iframe>\" place-id=\"<iframe src=&quot;https://www.google.com/maps/embed/v1/place?key&#x3D;AIzaSyCt1265A4qvZy9HKUeA8J15AOC4SrCyZe4&amp;q&#x3D;Anderson%20Island&quot;></iframe>\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Gradient\" name=\"showGradient\" checked condition=\"bg.type == 'color'\">\n        <input type=\"color\" title=\"Gradient Color\" value=\"#FCFBFA\" name=\"gradient\" condition=\"showGradient && bg.type == 'color'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12\">\n                <div class=\"content-wrapper\" mbr-if=\"showLabel || showTitle || showSubtitle || showText\">\n                    <p class=\"mbr-label mbr-fonts-style\" data-app-selector=\".mbr-label\" mbr-theme-style=\"display-7\" mbr-if=\"showLabel\">\n                        <b>Find Us</b>\n                    </p>\n                    <div class=\"title-wrapper\" mbr-if=\"showTitle || showSubtitle\">\n                        <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                            <b>Island Location</b>\n                        </h2>\n                        <h3 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-2\" mbr-if=\"showSubtitle\">\n                            <b>Get In Touch</b>\n                        </h3>\n                    </div>\n                    <div class=\"text-wrapper\">\n                        <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text, .text-wrapper\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">We&#x27;re right here on Anderson Island, ready to serve you. Come visit or give us a call. We&#x27;re easy to find!</p>\n                    </div>\n                </div>\n                <div class=\"google-map\" mbr-map=\"googleMap\"></div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_name": "map01",
          "_sourceTheme": "strengthm5",
          "_cid": "vbylUvT6Bg",
          "_anchor": "map-1-vbylUvT6Bg",
          "alias": false,
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        }
      ]
    }
  }
}