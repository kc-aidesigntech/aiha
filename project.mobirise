                  },
                  ".icon_3": {
                    ".mbr-iconfont": {
                      "background-color": "@iconBg_3",
                      "border-color": "@iconBorder_3",
                      "box-shadow": "0 18px 32px -8px @iconBg_3"
                    }
                  },
                  ".card-title": {
                    "margin-bottom": "16px"
                  },
                  ".card-text": {
                    "margin-bottom": "0"
                  }
                }
              }
            },
            ".card-title": {
              "color": "#111111"
            },
