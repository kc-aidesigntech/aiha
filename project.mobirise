                  }
                },
                ".item-wrapper": {
                  ".iconfont-wrapper": {
                    "margin-bottom": "32px",
                    "@media (max-width: 992px)": {
                      "margin-bottom": "24px"
                    },
                    ".mbr-iconfont": {
                      "display": "inline-flex",
                      "align-items": "center",
                      "justify-content": "center",
                      "width": "64px",
                      "height": "64px",
                      "border-radius": "100%",
                      "font-size": "28px",
                      "border": "4px solid"
                    }
                  },
                  ".icon_1": {
                    ".mbr-iconfont": {
                      "background-color": "@iconBg_1",
                      "border-color": "@iconBorder_1",
                      "box-shadow": "0 18px 32px -8px @iconBg_1"
                    }
                  },
                  ".icon_2": {
                    ".mbr-iconfont": {
                      "background-color": "@iconBg_2",
                      "border-color": "@iconBorder_2",
                      "box-shadow": "0 18px 32px -8px @iconBg_2"
                    }
                  },
                  ".icon_3": {
                    ".mbr-iconfont": {
                      "background-color": "@iconBg_3",
                      "border-color": "@iconBorder_3",
                      "box-shadow": "0 18px 32px -8px @iconBg_3"
                    }
                  },
                  ".card-title": {
                    "margin-bottom": "16px"
                  },
                  ".card-text": {
                    "margin-bottom": "0"
                  }
                }
              }
            },
            ".card-title": {
              "color": "#111111"
            },
            ".card-text": {
              "color": "#666666",
              "text-align": "center"
            },
            ".card-title, .iconfont-wrapper": {
              "text-align": "center",
              "color": "#4B2A00"
            },
            ".card-icon_1": {
              "color": "#000000"
            },
            ".card-icon_2": {
              "color": "#FFFFFF"
            },
            ".card-icon_3": {
              "color": "#000000"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features06 strengthm5\" group=\"Features\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <header>Icons</header>\n        <input type=\"checkbox\" title=\"Icon\" name=\"showIcon\" checked>\n        <input type=\"color\" title=\"Icon BG 1\" value=\"#9DB6CC\" name=\"iconBg_1\" selected>\n        <input type=\"color\" title=\"Icon Border 1\" value=\"#CFE8FF\" name=\"iconBorder_1\" selected>\n        <input type=\"color\" title=\"Icon BG 2\" value=\"#A47786\" name=\"iconBg_2\" selected>\n        <input type=\"color\" title=\"Icon Border 2\" value=\"#D6A6B6\" name=\"iconBorder_2\" selected>\n        <input type=\"color\" title=\"Icon BG 3\" value=\"#E4D4C8\" name=\"iconBg_3\" selected>\n        <input type=\"color\" title=\"Icon Border 3\" value=\"#FFFFFB\" name=\"iconBorder_3\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row items-wrapper justify-content-center\">\n            <div class=\"col-12 col-lg-4 item features-without-image\">\n                <div class=\"item-wrapper\">\n                    <div class=\"iconfont-wrapper icon_1\" mbr-if=\"showIcon\">\n                        <span mbr-icon=\"\" class=\"mbr-iconfont card-icon_1 mobi-mbri-user mobi-mbri\" data-app-selector=\".card-icon_1\"></span>\n                    </div>\n                    <p class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\">\n                        <b>Wellness</b>\n                    </p>\n                    <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">Proactive health programs and resources to keep you feeling your best. Your well-being is our priority.</p>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-4 item features-without-image\">\n                <div class=\"item-wrapper\">\n                    <div class=\"iconfont-wrapper icon_2\" mbr-if=\"showIcon\">\n                        <span mbr-icon=\"\" class=\"mbr-iconfont card-icon_2 mobi-mbri-protect mobi-mbri\" data-app-selector=\".card-icon_2\"></span>\n                    </div>\n                    <p class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\">\n                        <b>Plans</b>\n                    </p>\n                    <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">Flexible healthcare options designed to fit your life and budget. Get the coverage you need.</p>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-4 item features-without-image\">\n                <div class=\"item-wrapper\">\n                    <div class=\"iconfont-wrapper icon_3\" mbr-if=\"showIcon\">\n                        <span mbr-icon=\"\" class=\"mbr-iconfont card-icon_3 mobi-mbri-smile-face mobi-mbri\" data-app-selector=\".card-icon_3\"></span>\n                    </div>\n                    <p class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\">\n                        <b>Support</b>\n                    </p>\n                    <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">Dedicated assistance and guidance for all your healthcare needs. We&#x27;re here to help you.</p>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_name": "features06",
          "_sourceTheme": "strengthm5",
          "_cid": "vbylUuUTz4",
          "_anchor": "features-4-vbylUuUTz4",
          "alias": false,
          "_protectedParams": [],
