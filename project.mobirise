              "min-width": "360px",
              "max-width": "360px",
              "@media (max-width: 767px)": {
                "min-width": "100%",
                "max-width": "100%"
              },
              ".slide-content": {
                "width": "100%",
                ".item-wrapper": {
                  "position": "relative",
                  "height": "100%",
                  "padding": "32px",
                  "background-color": "@cardBg",
                  "box-shadow": "0 32px 64px -10px @shadow",
                  "@media (max-width: 992px)": {
                    "padding": "24px"
                  },
                  ".person-wrapper": {
                    "margin-bottom": "24px",
                    ".person-wrap": {
                      "display": "inline-flex",
                      "align-items": "center",
                      ".item-img": {
                        "img": {
                          "display": "inline-flex",
                          "width": "64px",
                          "height": "64px",
                          "min-width": "64px",
                          "object-fit": "cover",
                          "border-radius": "100% !important"
                        }
                      },
                      ".name-wrap": {
                        "padding-left": "24px",
                        ".item-name": {
                          "position": "relative",
                          "z-index": "1",
                          "margin-bottom": "0"
                        },
                        ".rating-wrapper": {
                          "position": "relative",
                          "z-index": "1",
                          ".rating-wrap": {
                            "display": "inline-flex",
                            "margin-bottom": "16px",
                            ".mbr-star": {
                              "margin-right": "2px",
                              "margin-bottom": "0",
                              "&:last-child": {
                                "margin-right": "0"
                              }
                            }
                          }
                        }
                      }
                    }
                  },
                  ".card-date": {
                    "position": "relative",
                    "z-index": "1",
                    "margin-bottom": "24px"
                  },
                  ".card-title": {
                    "position": "relative",
                    "z-index": "1",
                    "margin-bottom": "8px"
                  },
                  ".card-text": {
                    "position": "relative",
                    "z-index": "1",
                    "margin-bottom": "0"
                  }
                }
              }
            },
            ".embla__button--next, .embla__button--prev": {
              "display": "flex"
            },
            ".embla__button": {
              "top": "0",
              "width": "56px",
              "height": "56px",
              "font-size": "16px",
              "background-color": "@arrowsBg !important",
              "color": "@arrowsColor !important",
              "border": "none !important",
              "border-radius": "100%",
              "transition": "all 0.3s",
              "position": "absolute",
              "display": "flex",
              "justify-content": "center",
              "align-items": "center",
              "opacity": "1 !important",
              "& when not (@arrows)": {
                "display": "none"
              },
              "& when not (@arrowsMobile)": {
                "@media (max-width: 768px)": {
                  "display": "none"
                }
              },
              "&:hover": {
                "background-color": "@activeBg !important",
                "color": "@activeColor !important"
              },
              "&:disabled": {
                "background-color": "@arrowsBg !important",
                "color": "@arrowsColor !important",
                "opacity": "0.5 !important"
              },
              "&.embla__button--prev": {
                "left": "0",
                ".mbr-iconfont": {
                  "margin-right": "4px"
                }
              },
              "&.embla__button--next": {
                "right": "0",
                ".mbr-iconfont": {
                  "margin-left": "4px"
                }
              }
            },
            ".embla": {
              "position": "relative",
              "width": "100%",
              "@media (max-width: 992px)": {
                "padding": "0"
              },
              "& when (@arrows)": {
                "padding-top": "6rem"
              }
            },
            ".embla__viewport": {
              "overflow": "visible",
              "width": "100%"
            },
            ".embla__viewport.is-draggable": {
              "cursor": "grab"
            },
            ".embla__viewport.is-dragging": {
              "cursor": "grabbing"
            },
            ".embla__container": {
              "display": "flex",
              "user-select": "none",
              "-webkit-touch-callout": "none",
              "-khtml-user-select": "none",
              "-webkit-tap-highlight-color": "transparent"
            },
            ".mbr-section-btn": {
              "margin-top": "54px",
              "@media (max-width: 992px)": {
                "margin-top": "24px"
              },
              "text-align": "center"
            },
            ".item-menu-overlay": {
              "opacity": "0 !important"
            },
            ".item-name": {
              "color": "#111111"
            },
            ".card-date": {
              "color": "#666666"
            },
            ".card-title": {
              "color": "#111111"
            },
            ".card-text": {
              "color": "#666666"
            },
            ".mbr-star": {
              "color": "#ff6d99"
            },
            ".mbr-star, .rating-wrapper": {
              "color": "#6E869B"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"slider03 mbr-embla strengthm5\" group=\"Sliders & Galleries\" plugins=\"embla\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\" checked>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <header>Carousel</header>\n        <input type=\"checkbox\" title=\"Autoplay\" name=\"autoplay\" checked>\n        <input type=\"range\" title=\"Interval\" name=\"interval\" min=\"1\" max=\"10\" value=\"3\" step=\"1\" condition=\"autoplay\">\n        <input type=\"checkbox\" title=\"Loop\" name=\"loop\" checked>\n        <input type=\"checkbox\" title=\"Draggable\" name=\"draggable\" checked>\n        <input type=\"checkbox\" name=\"arrows\" title=\"Arrows\">\n        <input type=\"checkbox\" name=\"arrowsMobile\" title=\"Mobile Arrows\" condition=\"arrows\" checked>\n        <input type=\"color\" title=\"Arrows Color\" value=\"#ffffff\" name=\"arrowsColor\" condition=\"arrows\">\n        <input type=\"color\" title=\"Arrows BG\" value=\"#a6adbf\" name=\"arrowsBg\" condition=\"arrows\">\n        <input type=\"color\" title=\"Active Color\" value=\"#ffffff\" name=\"activeColor\" condition=\"arrows\">\n        <input type=\"color\" title=\"Active BG\" value=\"#7B86A1\" name=\"activeBg\" condition=\"arrows\">\n        <header>Cards</header>\n        <input type=\"range\" name=\"gap\" title=\"Gap\" min=\"0\" max=\"32\" step=\"8\" value=\"16\">\n        <input type=\"checkbox\" title=\"Name\" name=\"showName\" checked>\n        <input type=\"checkbox\" title=\"Rating\" name=\"showRating\" checked>\n        <input type=\"range\" inline title=\"Rating Amount\" name=\"rating\" min=\"1\" max=\"5\" step=\"1\" value=\"5\" condition=\"showRating\">\n        <input type=\"checkbox\" title=\"Date\" name=\"showDate\" checked>\n        <input type=\"checkbox\" title=\"Title\" name=\"showCardTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showCardText\" checked>\n        <input type=\"color\" title=\"BG\" value=\"#ffffff\" name=\"cardBg\" selected>\n        <input type=\"color\" title=\"Shadow\" value=\"#FCFBFA\" name=\"shadow\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax required>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Gradient\" name=\"showGradient\" checked condition=\"bg.type == 'color'\">\n        <input type=\"color\" title=\"Gradient Color\" value=\"#FCFBFA\" name=\"gradient\" condition=\"showGradient && bg.type == 'color'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#f4f4f4\" condition=\"overlay && bg.type == 'image'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type == 'image'\">\n    </mbr-parameters>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\" class=\"content-wrap\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"embla\" data-loop=\"{{loop}}\" data-auto-play=\"{{autoplay}}\" data-auto-play-interval=\"{{interval}}\" data-draggable=\"{{draggable}}\" data-skip-snaps=\"true\" data-align=\"center\" data-contain-scroll=\"trimSnaps\">\n                    <div class=\"embla__viewport\">\n                        <div class=\"embla__container\">\n                            <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper little-radius\">\n                                        <div class=\"person-wrapper\">\n                                            <div class=\"person-wrap\">\n                                                <div class=\"item-img\">\n                                                    <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/photo-1638868939857-11ac407b347a.jpeg\" alt=\"Mobirise Website Builder\">\n                                                </div>\n                                                <div class=\"name-wrap\" mbr-if=\"showName || showRating\">\n                                                    <p class=\"item-name mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showName\" data-app-selector=\".item-name, .person-wrapper\">Robert Chen</p>\n                                                    <div class=\"rating-wrapper\" mbr-if=\"showRating\">\n                                                        <div class=\"rating-wrap\">\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 1\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 2\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 3\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 4\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                        </div>\n                                                    </div>\n                                                </div>\n                                            </div>\n                                        </div>\n                                        <p class=\"card-date mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-date\" mbr-if=\"showDate\">2023-10-26</p>\n                                        <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-title\" mbr-if=\"showCardTitle\">\n                                            <b>Lifesaver!</b>\n                                        </h4>\n                                        <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text, .mbr-section-btn\" mbr-if=\"showCardText\">Anderson Island Health saved me a trip to the mainland. Fantastic service!</p>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper little-radius\">\n                                        <div class=\"person-wrapper\">\n                                            <div class=\"person-wrap\">\n                                                <div class=\"item-img\">\n                                                    <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/photo-1513207565459-d7f36bfa1222.jpeg\" alt=\"Mobirise Website Builder\">\n                                                </div>\n                                                <div class=\"name-wrap\" mbr-if=\"showName || showRating\">\n                                                    <p class=\"item-name mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showName\" data-app-selector=\".item-name, .person-wrapper\">Maria Garcia</p>\n                                                    <div class=\"rating-wrapper\" mbr-if=\"showRating\">\n                                                        <div class=\"rating-wrap\">\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 1\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 2\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 3\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 4\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                        </div>\n                                                    </div>\n                                                </div>\n                                            </div>\n                                        </div>\n                                        <p class=\"card-date mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-date\" mbr-if=\"showDate\">2023-11-15</p>\n                                        <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-title\" mbr-if=\"showCardTitle\">\n                                            <b>So Convenient</b>\n                                        </h4>\n                                        <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text, .mbr-section-btn\" mbr-if=\"showCardText\">Having these services right here makes managing my health so much easier. Truly appreciate it.</p>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper little-radius\">\n                                        <div class=\"person-wrapper\">\n                                            <div class=\"person-wrap\">\n                                                <div class=\"item-img\">\n                                                    <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/photo-1629114112651-a8c8c27fb851.jpeg\" alt=\"Mobirise Website Builder\">\n                                                </div>\n                                                <div class=\"name-wrap\" mbr-if=\"showName || showRating\">\n                                                    <p class=\"item-name mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showName\" data-app-selector=\".item-name, .person-wrapper\">David Lee</p>\n                                                    <div class=\"rating-wrapper\" mbr-if=\"showRating\">\n                                                        <div class=\"rating-wrap\">\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 1\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 2\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 3\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 4\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                        </div>\n                                                    </div>\n                                                </div>\n                                            </div>\n                                        </div>\n                                        <p class=\"card-date mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-date\" mbr-if=\"showDate\">2024-01-01</p>\n                                        <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-title\" mbr-if=\"showCardTitle\">\n                                            <b>Community Focused</b>\n                                        </h4>\n                                        <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text, .mbr-section-btn\" mbr-if=\"showCardText\">It&#x27;s wonderful to see an organization so dedicated to the well-being of our island residents.</p>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper little-radius\">\n                                        <div class=\"person-wrapper\">\n                                            <div class=\"person-wrap\">\n                                                <div class=\"item-img\">\n                                                    <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/photo-1606081430924-b6480765d470.jpeg\" alt=\"Mobirise Website Builder\">\n                                                </div>\n                                                <div class=\"name-wrap\" mbr-if=\"showName || showRating\">\n                                                    <p class=\"item-name mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showName\" data-app-selector=\".item-name, .person-wrapper\">Sarah Kim</p>\n                                                    <div class=\"rating-wrapper\" mbr-if=\"showRating\">\n                                                        <div class=\"rating-wrap\">\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 1\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 2\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 3\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 4\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                        </div>\n                                                    </div>\n                                                </div>\n                                            </div>\n                                        </div>\n                                        <p class=\"card-date mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-date\" mbr-if=\"showDate\">2024-02-10</p>\n                                        <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-title\" mbr-if=\"showCardTitle\">\n                                            <b>Excellent Care</b>\n                                        </h4>\n                                        <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text, .mbr-section-btn\" mbr-if=\"showCardText\">The staff are knowledgeable and friendly. I felt well taken care of during my visit.</p>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper little-radius\">\n                                        <div class=\"person-wrapper\">\n                                            <div class=\"person-wrap\">\n                                                <div class=\"item-img\">\n                                                    <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/photo-1658335786123-b4b2b56a8c1d.jpeg\" alt=\"Mobirise Website Builder\">\n                                                </div>\n                                                <div class=\"name-wrap\" mbr-if=\"showName || showRating\">\n                                                    <p class=\"item-name mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showName\" data-app-selector=\".item-name, .person-wrapper\">Michael Brown</p>\n                                                    <div class=\"rating-wrapper\" mbr-if=\"showRating\">\n                                                        <div class=\"rating-wrap\"><p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 1\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 2\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 3\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 4\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                        </div>\n                                                    </div>\n                                                </div>\n                                            </div>\n                                        </div>\n                                        <p class=\"card-date mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-date\" mbr-if=\"showDate\">2024-03-22</p>\n                                        <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-title\" mbr-if=\"showCardTitle\">\n                                            <b>Game Changer</b>\n                                        </h4>\n                                        <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text, .mbr-section-btn\" mbr-if=\"showCardText\">This initiative is a game-changer for island healthcare. So grateful for the accessibility.</p>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper little-radius\">\n                                        <div class=\"person-wrapper\">\n                                            <div class=\"person-wrap\">\n                                                <div class=\"item-img\">\n                                                    <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/photo-1510274642460-65a8de5e52fd.jpeg\" alt=\"Mobirise Website Builder\">\n                                                </div>\n                                                <div class=\"name-wrap\" mbr-if=\"showName || showRating\">\n                                                    <p class=\"item-name mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showName\" data-app-selector=\".item-name, .person-wrapper\">Emily White</p>\n                                                    <div class=\"rating-wrapper\" mbr-if=\"showRating\">\n                                                        <div class=\"rating-wrap\">\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 1\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 2\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 3\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                            <p class=\"mbr-star mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"rating > 4\" data-app-selector=\".mbr-star, .rating-wrapper\">★</p>\n                                                        </div>\n                                                    </div>\n                                                </div>\n                                            </div>\n                                        </div>\n                                        <p class=\"card-date mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-date\" mbr-if=\"showDate\">2024-04-05</p>\n                                        <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-title\" mbr-if=\"showCardTitle\">\n                                            <b>Peace of Mind</b>\n                                        </h4>\n                                        <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text, .mbr-section-btn\" mbr-if=\"showCardText\">Knowing I can get quality care without a long ferry ride brings immense peace of mind.</p>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <button class=\"embla__button embla__button--prev\">\n                        <span class=\"mobi-mbri mobi-mbri-arrow-prev mbr-iconfont\" aria-hidden=\"true\"></span>\n                        <span class=\"sr-only visually-hidden visually-hidden visually-hidden visually-hidden visually-hidden\">Previous</span>\n                    </button>\n                    <button class=\"embla__button embla__button--next\">\n                        <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont\" aria-hidden=\"true\"></span>\n                        <span class=\"sr-only visually-hidden visually-hidden visually-hidden visually-hidden visually-hidden\">Next</span>\n                    </button>\n                </div>\n                <div mbr-buttons=\"\" mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                    <a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                        <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                        Donate Now\n                    </a>\n                    <a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                        <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                        Learn More\n                    </a>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
