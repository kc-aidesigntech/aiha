                        "min-width": "32px",
                        "display": "inline-flex",
                        "align-items": "center",
                        "justify-content": "center",
                        "margin-left": "24px",
                        "transition": "all 0.3s ease-in-out",
                        "border-radius": "100%",
                        "background-color": "@iconBg",
                        ".mbr-iconfont": {
                          "margin-top": "4px",
                          "font-size": "12px",
                          "transition": "all 0.3s ease-in-out",
                          "color": "@iconColor"
                        },
                        "&:hover": {
                          "background-color": "@activeBg",
                          ".mbr-iconfont": {
                            "color": "@activeColor"
