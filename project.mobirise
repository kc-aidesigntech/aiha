        {
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "align-items": "flex-end",
            "& when (@fullScreen)": {
              "padding-top": "5rem",
              "padding-bottom": "5rem"
            },
            "& when (@showGradient)": {
              "position": "relative",
              "&::before": {
                "content": "''",
                "position": "absolute",
                "bottom": "0",
                "left": "0",
                "width": "100%",
                "height": "100%",
                "background-image": "linear-gradient(transparent 0, @gradient 120%)",
                "pointer-events": "none"
              }
            },
            "justify-content": "flex-end",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".card": {
              "justify-content": "flex-end"
            },
            ".content-wrapper": {
              ".mbr-label": {
                "margin-bottom": "32px"
              },
              ".mbr-section-title": {
                "margin-bottom": "32px"
              },
              ".mbr-text": {
                "margin-bottom": "0"
              },
              ".mbr-section-btn": {
                ".btn": {
                  "margin-top": "32px",
                  "& when (@bg-type = 'image')": {
                    "box-shadow": "none !important"
                  }
                }
              }
            },
            ".mbr-label": {
              "color": "#ffffff"
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-text": {
              "color": "#ffffff"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"header02 strengthm5\" group=\"Headers\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"15\" step=\"1\" value=\"15\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"15\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Label\" name=\"showLabel\" checked>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/ferry.2.jpg-2000x1163.jpg\" parallax selected>\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\">\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background2.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Gradient\" name=\"showGradient\" checked>\n        <input type=\"color\" title=\"Gradient Color\" value=\"#006475\" name=\"gradient\" condition=\"showGradient\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#111111\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-7\">\n                <div class=\"content-wrapper\">\n                    <p class=\"mbr-label mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showLabel\" data-app-selector=\".mbr-label\"></p>\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\">\n                        <b>Primary Care is Coming</b></h2>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">Committed to making it easier for you to access the health care you need via Peninsula Community Health Services (PCHS)</p>\n                    <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-info\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                            <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                            Donate today</a>   <a class=\"btn btn-white\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                            <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                            Volunteer with us</a></div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_name": "header02",
          "_sourceTheme": "strengthm5",
          "_cid": "vbylUtW8zk",
          "_anchor": "hero-2-vbylUtW8zk",
          "alias": false,
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".content-wrapper": {
              "margin-bottom": "80px",
              "@media (max-width: 992px)": {
                "margin-bottom": "32px"
              },
              ".title-wrapper": {
                "margin-bottom": "16px",
                ".mbr-section-title": {
                  "margin-bottom": "0"
                },
                ".mbr-section-subtitle": {
                  "margin-bottom": "0"
                }
              },
              ".text-wrapper": {
                ".mbr-text": {
                  "display": "inline-block",
                  "width": "50%",
                  "margin-bottom": "0",
                  "@media (max-width: 992px)": {
                    "width": "100%"
                  }
                }
              }
            },
            ".items-wrapper": {
              "margin": "0 -8px",
              "align-items": "center",
              ".item": {
                "padding": "0 8px",
                "margin-bottom": "16px",
                ".item-wrapper": {
                  "position": "relative",
                  "overflow": "hidden",
                  ".gradient-wrap": {
                    "position": "absolute",
                    "top": "0",
                    "left": "0",
                    "width": "100%",
                    "height": "100%",
                    "background-image": "linear-gradient(180deg, transparent, @gradient)",
                    "opacity": "0.3"
                  },
                  ".circle-wrap": {
                    "position": "absolute",
                    "top": "-90%",
                    "left": "-40%",
                    "width": "640px",
                    "height": "640px",
                    "border-radius": "100%",
                    "background-image": "linear-gradient(0deg, transparent, @gradient)",
                    "opacity": "0.3",
                    "z-index": "1",
                    "@media (max-width: 1200px)": {
                      "left": "-70%"
                    },
                    "@media (max-width: 768px)": {
                      "left": "-120%"
                    },
                    "@media (max-width: 425px)": {
                      "left": "-160%"
                    }
                  },
                  ".circle-wrap.reverse": {
                    "top": "auto",
                    "left": "auto",
                    "bottom": "-90%",
                    "right": "-40%",
                    "background-image": "linear-gradient(180deg, transparent, @gradient)",
                    "@media (max-width: 1200px)": {
                      "left": "auto",
                      "right": "-70%"
                    },
                    "@media (max-width: 768px)": {
                      "left": "auto",
                      "right": "-120%"
                    },
                    "@media (max-width: 425px)": {
                      "left": "auto",
                      "right": "-160%"
                    }
                  },
                  ".iconfont-wrapper": {
                    "position": "absolute",
                    "top": "28px",
                    "right": "28px",
                    "width": "20px",
                    "height": "20px",
                    "z-index": "1",
                    "@media (max-width: 992px)": {
                      "top": "16px",
                      "right": "16px"
                    },
                    ".mbr-iconfont": {
                      "font-size": "18px"
                    }
                  },
                  ".item-content": {
                    "display": "flex",
                    "justify-content": "space-between",
                    "padding": "32px",
                    "min-height": "330px",
                    "border": "8px solid",
                    "@media (max-width: 992px)": {
                      "display": "block",
                      "padding": "24px",
                      "min-height": "auto",
                      "border": "4px solid"
                    },
                    ".card-box": {
                      "position": "relative",
                      "z-index": "1",
                      "@media (max-width: 992px)": {
                        "margin-bottom": "24px"
                      },
                      ".card-title_1, .card-title_2, .card-title_3, .card-title_4": {
                        "margin-bottom": "16px"
                      },
                      ".card-text_1, .card-text_2, .card-text_3, .card-text_4": {
                        "margin-bottom": "0"
                      },
                      ".mbr-section-btn": {
                        "margin-top": "24px",
                        ".btn": {
                          "margin-bottom": "0",
                          "box-shadow": "none !important"
                        }
                      }
                    },
                    ".item-img": {
                      "position": "relative",
                      "z-index": "1",
                      "display": "flex",
                      "align-items": "flex-end",
                      "margin-right": "24px",
                      "@media (max-width: 992px)": {
                        "display": "block",
                        "margin-right": "0"
                      },
                      "img": {
                        "width": "200px",
                        "height": "200px",
                        "object-fit": "cover",
                        "border-radius": "100% !important",
                        "@media (max-width: 992px)": {
                          "margin": "0 auto"
                        }
                      }
                    }
                  },
                  ".card_1, .card_4": {
                    ".card-box": {
                      "width": "50%",
                      "@media (max-width: 992px)": {
                        "width": "100%"
                      }
                    }
                  },
                  ".card_1": {
                    "background-color": "@cardBg_1",
                    "border-color": "@border_1"
                  },
                  ".card_2": {
                    "background-color": "@cardBg_2",
                    "border-color": "@border_2"
                  },
                  ".card_3": {
                    "background-color": "@cardBg_3",
                    "border-color": "@border_3"
                  },
                  ".card_4": {
                    "background-color": "@cardBg_4",
                    "border-color": "@border_4"
                  }
                }
              }
            },
            ".btn-wrapper": {
              "margin-right": "9%"
            },
            ".mbr-label": {
              "color": "#4B2A00",
              "text-align": "center"
            },
            ".mbr-section-title": {
              "color": "#111111",
              "text-align": "center"
            },
            ".mbr-section-subtitle": {
              "color": "#6E869B",
              "text-align": "center"
            },
            ".mbr-text, .text-wrapper": {
              "color": "#666666",
              "text-align": "center"
            },
            ".card-title_1": {
              "color": "#ffffff"
            },
            ".card-title_2": {
              "color": "#FFFFFF"
            },
            ".card-title_3": {
              "color": "#000000"
            },
            ".card-title_4": {
              "color": "#ffffff"
            },
            ".card-text_1": {
              "color": "#000000"
            },
            ".card-text_2": {
              "color": "#FFFFFF"
            },
            ".card-text_3": {
              "color": "#000000"
            },
            ".card-text_4": {
              "color": "#000000"
            },
            ".card-icon": {
              "color": "#000000"
            },
            ".card-title_1, .mbr-section-btn": {
              "color": "#000000"
            },
            ".card-title_4, .mbr-section-btn": {
              "color": "#000000"
            },
            ".card-icon_1": {
              "color": "#000000"
