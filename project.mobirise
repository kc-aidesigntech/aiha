              "text-align": "center"
            },
            ".card-title, .iconfont-wrapper": {
              "text-align": "center"
            }
          },
          "_name": "features06",
          "_sourceTheme": "strengthm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features06 strengthm5\" group=\"Features\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <header>Icons</header>\n        <input type=\"checkbox\" title=\"Icon\" name=\"showIcon\" checked>\n        <input type=\"color\" title=\"Icon BG 1\" value=\"#006475\" name=\"iconBg_1\" selected>\n        <input type=\"color\" title=\"Icon Border 1\" value=\"#ffffff\" name=\"iconBorder_1\" selected>\n        <input type=\"color\" title=\"Icon BG 2\" value=\"#326853\" name=\"iconBg_2\" selected>\n        <input type=\"color\" title=\"Icon Border 2\" value=\"#ffffff\" name=\"iconBorder_2\" selected>\n        <input type=\"color\" title=\"Icon BG 3\" value=\"#ff5f73\" name=\"iconBg_3\" selected>\n        <input type=\"color\" title=\"Icon Border 3\" value=\"#ffffff\" name=\"iconBorder_3\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row items-wrapper justify-content-center\">\n            \n            <div class=\"col-12 col-lg-4 item features-without-image active\">\n                <div class=\"item-wrapper\">\n                    <div class=\"iconfont-wrapper icon_1\" mbr-if=\"showIcon\">\n                        <span mbr-icon class=\"mbr-iconfont card-icon mobi-mbri-success mobi-mbri\" data-app-selector=\".card-icon\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255);\"></span>\n                    </div>\n                    <p class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\">\n                        <b>1 - Define Our Need for </b><br><b>PCHS Mobile Clinic</b><br><i>COMPLETE</i></p>\n                    <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">\n                        Whether you’re aiming see a doctor for the first time in a long time, simply wanting to avoid the ferry, or needing urgent care, we adapt to your needs.<br></p>\n                </div>\n            </div><div class=\"col-12 col-lg-4 item features-without-image\">\n                <div class=\"item-wrapper\">\n                    <div class=\"iconfont-wrapper icon_2\" mbr-if=\"showIcon\">\n                        <span mbr-icon class=\"mbr-iconfont card-icon mobi-mbri-cash mobi-mbri\" data-app-selector=\".card-icon\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255);\"></span>\n                    </div>\n                    <p class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\"><b>2 - Secure Resources</b><br><i style>IN PROGRESS</i><br><i style><br></i></p>\n                    <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">AIHA is budgeting $82K per year to bring healthcare to your doorstop.<br><br>Help us get to our goal!</p>\n                </div>\n            </div><div class=\"col-12 col-lg-4 item features-without-image\">\n                <div class=\"item-wrapper\">\n                    <div class=\"iconfont-wrapper icon_3\" mbr-if=\"showIcon\">\n                        <span mbr-icon class=\"mbr-iconfont card-icon mobi-mbri-rocket mobi-mbri\" data-app-selector=\".card-icon\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255);\"></span>\n                    </div>\n                    <p class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\">\n                        <b>3 - Mobile Clinic Begins Scheduled Visits here on Anderson Island</b></p>\n                    <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">\n                        With consistent support and encouragement, trainers help you stay on track, overcome challenges,\n                        and maintain long-term commitment.\n                    </p>\n                </div>\n            </div>\n            \n        </div>\n    </div>\n</section>",
          "_cid": "vdXU2ygM6v",
          "_anchor": "features06-1",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".content-wrapper": {
              "margin-bottom": "80px",
              "@media (max-width: 992px)": {
                "margin-bottom": "32px"
              },
              ".title-wrapper": {
                "margin-bottom": "16px",
                ".mbr-section-title": {
                  "margin-bottom": "0"
                },
                ".mbr-section-subtitle": {
                  "margin-bottom": "0"
                }
              },
              ".text-wrapper": {
                ".mbr-text": {
                  "display": "inline-block",
                  "width": "50%",
                  "margin-bottom": "0",
                  "@media (max-width: 992px)": {
                    "width": "100%"
                  }
                }
              }
            },
            ".items-wrapper": {
              "margin": "0 -8px",
              "align-items": "center",
              ".item": {
                "padding": "0 8px",
                "margin-bottom": "16px",
                ".item-wrapper": {
                  "position": "relative",
                  "overflow": "hidden",
                  ".gradient-wrap": {
                    "position": "absolute",
                    "top": "0",
                    "left": "0",
                    "width": "100%",
                    "height": "100%",
                    "background-image": "linear-gradient(180deg, transparent, @gradient)",
                    "opacity": "0.3"
                  },
                  ".circle-wrap": {
                    "position": "absolute",
                    "top": "-90%",
                    "left": "-40%",
                    "width": "640px",
                    "height": "640px",
                    "border-radius": "100%",
                    "background-image": "linear-gradient(0deg, transparent, @gradient)",
                    "opacity": "0.3",
                    "z-index": "1",
                    "@media (max-width: 1200px)": {
                      "left": "-70%"
                    },
                    "@media (max-width: 768px)": {
                      "left": "-120%"
                    },
                    "@media (max-width: 425px)": {
                      "left": "-160%"
                    }
                  },
                  ".circle-wrap.reverse": {
                    "top": "auto",
                    "left": "auto",
                    "bottom": "-90%",
                    "right": "-40%",
                    "background-image": "linear-gradient(180deg, transparent, @gradient)",
                    "@media (max-width: 1200px)": {
                      "left": "auto",
                      "right": "-70%"
                    },
                    "@media (max-width: 768px)": {
                      "left": "auto",
                      "right": "-120%"
                    },
                    "@media (max-width: 425px)": {
                      "left": "auto",
                      "right": "-160%"
                    }
                  },
                  ".iconfont-wrapper": {
                    "position": "absolute",
                    "top": "28px",
                    "right": "28px",
                    "width": "20px",
                    "height": "20px",
                    "z-index": "1",
                    "@media (max-width: 992px)": {
                      "top": "16px",
                      "right": "16px"
                    },
                    ".mbr-iconfont": {
                      "font-size": "18px"
                    }
                  },
                  ".item-content": {
                    "display": "flex",
                    "justify-content": "space-between",
                    "padding": "32px",
                    "min-height": "330px",
                    "border": "8px solid",
                    "@media (max-width: 992px)": {
                      "display": "block",
                      "padding": "24px",
                      "min-height": "auto",
                      "border": "4px solid"
                    },
                    ".card-box": {
                      "position": "relative",
                      "z-index": "1",
                      "@media (max-width: 992px)": {
                        "margin-bottom": "24px"
                      },
                      ".card-title_1, .card-title_2, .card-title_3, .card-title_4": {
                        "margin-bottom": "16px"
                      },
                      ".card-text_1, .card-text_2, .card-text_3, .card-text_4": {
                        "margin-bottom": "0"
                      },
                      ".mbr-section-btn": {
                        "margin-top": "24px",
                        ".btn": {
                          "margin-bottom": "0",
                          "box-shadow": "none !important"
                        }
                      }
                    },
                    ".item-img": {
                      "position": "relative",
                      "z-index": "1",
                      "display": "flex",
                      "align-items": "flex-end",
                      "margin-right": "24px",
                      "@media (max-width: 992px)": {
                        "display": "block",
                        "margin-right": "0"
                      },
                      "img": {
                        "width": "200px",
                        "height": "200px",
                        "object-fit": "cover",
                        "border-radius": "100% !important",
                        "@media (max-width: 992px)": {
                          "margin": "0 auto"
                        }
                      }
                    }
                  },
                  ".card_1, .card_4": {
                    ".card-box": {
                      "width": "50%",
                      "@media (max-width: 992px)": {
                        "width": "100%"
                      }
                    }
                  },
                  ".card_1": {
                    "background-color": "@cardBg_1",
                    "border-color": "@border_1"
                  },
                  ".card_2": {
                    "background-color": "@cardBg_2",
                    "border-color": "@border_2"
                  },
                  ".card_3": {
                    "background-color": "@cardBg_3",
                    "border-color": "@border_3"
                  },
                  ".card_4": {
                    "background-color": "@cardBg_4",
                    "border-color": "@border_4"
                  }
                }
              }
            },
            ".btn-wrapper": {
              "margin-right": "9%"
            },
            ".mbr-label": {
              "color": "#4B2A00",
              "text-align": "center"
            },
            ".mbr-section-title": {
              "color": "#ffffff",
              "text-align": "center"
            },
            ".mbr-section-subtitle": {
              "color": "#cfe8ff",
              "text-align": "center"
            },
            ".mbr-text, .text-wrapper": {
              "color": "#ffffff",
              "text-align": "center"
            },
            ".card-title_1": {
              "color": "#ffffff"
            },
            ".card-title_2": {
              "color": "#FFFFFF"
            },
            ".card-title_3": {
              "color": "#ffffff"
            },
            ".card-title_4": {
              "color": "#ffffff"
            },
            ".card-text_1": {
              "color": "#000000"
            },
            ".card-text_2": {
              "color": "#FFFFFF"
            },
            ".card-text_3": {
              "color": "#ffffff"
            },
            ".card-text_4": {
              "color": "#002e36"
            },
            ".card-icon": {
              "color": "#000000"
            },
            ".card-title_1, .mbr-section-btn": {
              "color": "#000000"
            },
            ".card-title_4, .mbr-section-btn": {
              "color": "#002e36"
            },
            ".card-icon_1": {
              "color": "#000000"
            },
            ".card-icon_2": {
              "color": "#FFFFFF"
            },
            ".card-icon_3": {
              "color": "#000000"
            },
            ".card-icon_4": {
              "color": "#000000"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features03 strengthm5\" group=\"Features\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Label\" name=\"showLabel\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Icon\" name=\"showIcon\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showCardTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showCardText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <header>Card Colours</header>\n        <input type=\"color\" title=\"BG 1\" value=\"#9DB6CC\" name=\"cardBg_1\" selected>\n        <input type=\"color\" title=\"Border 1\" value=\"#CFE8FF\" name=\"border_1\" selected>\n        <input type=\"color\" title=\"BG 2\" value=\"#ff5f73\" name=\"cardBg_2\" selected>\n        <input type=\"color\" title=\"Border 2\" value=\"#ffffff\" name=\"border_2\" selected>\n        <input type=\"color\" title=\"BG 3\" value=\"#006475\" name=\"cardBg_3\" selected>\n        <input type=\"color\" title=\"Border 3\" value=\"#FFFFFB\" name=\"border_3\" selected>\n        <input type=\"color\" title=\"BG 4\" value=\"#f07a6d\" name=\"cardBg_4\" selected>\n        <input type=\"color\" title=\"Border 4\" value=\"#ffb4b4\" name=\"border_4\" selected>\n        <input type=\"color\" title=\"Gradient Color\" value=\"#ffffff\" name=\"gradient\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#002e36\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"content-wrapper\" mbr-if=\"showLabel || showTitle || showSubtitle || showText\">\n                    <p class=\"mbr-label mbr-fonts-style\" data-app-selector=\".mbr-label\" mbr-theme-style=\"display-7\" mbr-if=\"showLabel\">Services You Requested</p>\n                    <div class=\"title-wrapper\" mbr-if=\"showTitle || showSubtitle\">\n                        <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                            <b>Professional Care For You</b>\n                        </h2>\n                        <h3 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-2\" mbr-if=\"showSubtitle\">\n                            <b>Tailored to Island Life</b>\n                        </h3>\n                    </div>\n                    <div class=\"text-wrapper\">\n                        <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text, .text-wrapper\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">We are excited to announce the first phase of our multiyear plan to bring primary care to Anderson Island via a mobile medical van.<br></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n        <div class=\"row items-wrapper justify-content-center\">\n            <div class=\"col-12 col-lg-7 item features-image\">\n                <div class=\"item-wrapper\">\n                    <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                        <span mbr-icon class=\"mbr-iconfont card-icon_1 mobi-mbri-right mobi-mbri\" data-app-selector=\".card-icon_1\"></span>\n                    </div>\n                    <div class=\"gradient-wrap card-wrap\"></div>\n                    <div class=\"circle-wrap\"></div>\n                    <div class=\"item-content card-wrap card_1\">\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title_1 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title_1, .mbr-section-btn\">\n                                <b>Wellness</b>\n                            </h4>\n                            <p class=\"card-text_1 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text_1\">Boost your health with the PCHS program.</p>\n                            <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                <a class=\"btn btn-white\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                    <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                                    View More\n                                </a>\n                            </div>\n                        </div>\n                        <div class=\"item-img\">\n                            <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/img-4795-2.png-400x400.png\" alt=\"Mobirise Website Builder\">\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-5 item features-without-image\">\n                <div class=\"item-wrapper\">\n                    <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                        <span mbr-icon class=\"mbr-iconfont card-icon_2 mobi-mbri-right mobi-mbri\" data-app-selector=\".card-icon_2\"></span>\n                    </div>\n                    <div class=\"gradient-wrap card-wrap\"></div>\n                    <div class=\"circle-wrap\"></div>\n                    <div class=\"item-content card-wrap card_2\">\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title_2 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title_2\">\n                                <b>Support</b>\n                            </h4>\n                            <p class=\"card-text_2 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text_2\">Care where you need it most.</p>\n                            <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                <a class=\"btn btn-white\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                    <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                                    View More\n                                </a>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-5 item features-without-image\">\n                <div class=\"item-wrapper\">\n                    <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                        <span mbr-icon class=\"mbr-iconfont card-icon_3 mobi-mbri-right mobi-mbri\" data-app-selector=\".card-icon_3\"></span>\n                    </div>\n                    <div class=\"gradient-wrap card-wrap\"></div>\n                    <div class=\"circle-wrap reverse\"></div>\n                    <div class=\"item-content card-wrap card_3\">\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title_3 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title_3\">\n                                 <b>Plans</b>\n                            </h4>\n                            <p class=\"card-text_3 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text_3\">Essential service that fits your life.</p>\n                            <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                <a class=\"btn btn-white\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                    <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                                    View More\n                                </a>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-7 item features-image\">\n                <div class=\"item-wrapper\">\n                    <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                        <span mbr-icon class=\"mbr-iconfont card-icon_4 mobi-mbri-right mobi-mbri\" data-app-selector=\".card-icon_4\"></span>\n                    </div>\n                    <div class=\"gradient-wrap card-wrap\"></div>\n                    <div class=\"circle-wrap reverse\"></div>\n                    <div class=\"item-content card-wrap card_4\">\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title_4 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title_4, .mbr-section-btn\">\n                                <b>Community</b>\n                            </h4>\n                            <p class=\"card-text_4 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text_4\">Connect with your neighbors.</p>\n                            <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                <a class=\"btn btn-white\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                    <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                                    View More\n                                </a>\n                            </div>\n                        </div>\n                        <div class=\"item-img\">\n                            <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/dsc02829-copy.jpg-400x570.jpg\" alt=\"Mobirise Website Builder\">\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_name": "features03",
          "_sourceTheme": "strengthm5",
          "_cid": "vbylUuurY4",
          "_anchor": "features-2-vbylUuurY4",
          "alias": false,
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "align-items": "flex-end",
            "& when (@fullScreen)": {
              "padding-top": "5rem",
              "padding-bottom": "5rem"
            },
            "& when (@showBlur)": {
              "position": "relative",
              "&::before": {
                "content": "''",
                "position": "absolute",
                "bottom": "0",
                "left": "0",
                "width": "100%",
                "height": "60%",
                "backdrop-filter": "blur(20px)",
                "mask-image": "linear-gradient(0deg, #000000 45%, transparent 55%)",
                "-webkit-mask-image": "linear-gradient(0deg, #000000 45%, transparent 55%)",
                "pointer-events": "none"
              }
            },
            "justify-content": "flex-end",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".card": {
              "justify-content": "flex-end"
            },
            ".title-wrapper": {
              "@media (max-width: 992px)": {
                "margin-bottom": "32px"
              },
              ".mbr-label": {
                "margin-bottom": "32px"
              },
              ".mbr-section-title": {
                "margin-bottom": "0"
              }
            },
            ".text-wrapper": {
              "padding-left": "260px",
              "@media (max-width: 1440px)": {
                "padding-left": "80px"
              },
              "@media (max-width: 992px)": {
                "padding-left": "0"
              },
              "& when (@reverseContent)": {
                "padding-left": "0",
                "padding-right": "260px",
                "@media (max-width: 1440px)": {
                  "padding-left": "0",
                  "padding-right": "80px"
                },
                "@media (max-width: 992px)": {
                  "padding-right": "0"
                }
              },
              ".mbr-text": {
                "margin-bottom": "40px",
                "@media (max-width: 992px)": {
                  "margin-bottom": "24px"
                }
              },
              ".mbr-section-btn": {
                ".btn": {
                  "margin-bottom": "0",
                  "& when (@bg-type = 'image')": {
                    "box-shadow": "none !important"
                  }
                }
              }
            },
            ".mbr-label": {
              "color": "#ffffff"
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-text": {
              "color": "#ffffff"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"header01 strengthm5\" group=\"Headers\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"15\" step=\"1\" value=\"4\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"15\" step=\"1\" value=\"2\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Label\" name=\"showLabel\" checked>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <input type=\"checkbox\" title=\"Blur\" name=\"showBlur\" condition=\"bg.type == 'image'\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/img-4795-2.2.jpg-2000x1500.jpg\" parallax selected>\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\">\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#111111\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.3\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-5 card\">\n                <div class=\"title-wrapper\">\n                    <p class=\"mbr-label mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showLabel\" data-app-selector=\".mbr-label\">\n\t\t\t\t\t\t<b>Transporting the doctor's office to a convenient place <br>on island.</b><b><br></b></p>\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\">\n                        <b>Mobile Medical Clinic</b></h2>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-5 card\">\n                <div class=\"text-wrapper\">\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\"><b>Breathe deep, live well.&nbsp;<br></b><br>We are excited to announce the first phase of our multiyear plan to bring primary care to Anderson Island via a mobile medical van provided by PCHS.<br><br></p>\n                    <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-white\" href=\"https://www.pchsweb.org/mobile-locations/mobile-medical-clinic/\" data-app-placeholder=\"Type Text\" target=\"_blank\">\n                            <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                            Learn More About PCHS</a></div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_name": "header01",
          "_sourceTheme": "strengthm5",
          "_cid": "vbylUu0g1m",
