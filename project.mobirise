                  },
                  ".card-header": {
                    "background-color": "transparent",
                    "border": "none",
                    "border-radius": "0",
                    "padding": "0",
                    ".panel-title": {
                      "display": "flex",
                      "justify-content": "space-between",
                      "align-items": "center",
                      "width": "100%",
                      ".panel-title-edit": {
                        "margin-bottom": "0",
                        "transition": "all 0.3s ease-in-out"
                      },
                      ".icon-wrapper": {
                        "width": "32px",
