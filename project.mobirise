              },
              ".form-wrap": {
                ".dragArea.row": {
                  "margin": "0 -9.6px",
                  ".form-group": {
                    "margin-bottom": "0 !important",
                    ".form-control-label": {
                      "margin-bottom": "8px"
                    },
                    ".form-control": {
                      "background-color": "@inputBg",
                      "padding": "15px 24px",
                      "box-shadow": "none",
                      "border": "1px solid @border !important",
                      "margin-bottom": "16px",
                      "&::placeholder": {
                        "color": "@inputColor"
                      },
                      "&:hover, &:focus": {
                        "box-shadow": "none",
                        "border": "1px solid @activeColor !important"
                      }
                    },
                    "textarea": {
                      "min-height": "64px"
                    },
                    ".form-check": {
                      "padding-left": "2.1em",
                      ".form-check-input": {
                        "background-color": "@inputColor",
                        "border-color": "@inputColor"
                      }
                    }
                  },
                  ".mbr-section-btn": {
                    "width": "100%",
                    "margin-top": "24px",
                    "@media (max-width: 992px)": {
                      "margin-top": "0"
                    },
                    ".btn": {
                      "margin-top": "0",
                      "margin-bottom": "0"
                    }
                  }
                }
              }
            },
            ".image-wrapper": {
              "img": {
                "height": "680px",
                "width": "100%",
                "object-fit": "cover",
                "@media (max-width: 1440px)": {
                  "height": "550px"
                },
                "@media (max-width: 992px)": {
                  "height": "350px"
                }
              }
            },
            ".mbr-label": {
              "color": "#ffffff"
            },
            ".mbr-section-title": {
              "color": "#111111"
            },
            ".mbr-section-subtitle": {
              "color": "#29d1ed"
            },
            ".mbr-section-title, .mbr-section-btn": {
              "color": "#e1e7f2"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"form01 strengthm5\" group=\"Form\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Label\" name=\"showLabel\" checked>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <header>Form</header>\n        <input type=\"color\" title=\"Input Color\" value=\"#ff5f73\" name=\"inputColor\" selected>\n        <input type=\"color\" title=\"Input BG\" value=\"#ffffff\" name=\"inputBg\" selected>\n        <input type=\"color\" title=\"Input Border\" value=\"#ffffff\" name=\"border\" selected>\n        <input type=\"color\" title=\"Active Color\" value=\"#e1e7f2\" name=\"activeColor\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#002e36\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-4 card\">\n                <div class=\"content-wrapper\">\n                    <p class=\"mbr-label mbr-fonts-style\" data-app-selector=\".mbr-label\" mbr-theme-style=\"display-7\" mbr-if=\"showLabel\">\n                        <b>Get In Touch</b>\n                    </p>\n                    <div class=\"title-wrapper\" mbr-if=\"showTitle || showSubtitle\">\n                        <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\">\n                            <b>Send Us A Message</b>\n                        </h2>\n                        <h3 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\" mbr-if=\"showSubtitle\">\n                            <b>We're eager to hear from you!</b>\n                        </h3>\n                    </div>\n                    <div mbr-form class=\"mbr-form form-wrap\">\n                        <!--Formbuilder Form-->\n                        <form action=\"admin@andersonislandhealth.org\" name=\"Form Name\" method=\"POST\" class=\"mbr-form form-with-styler\" data-verified=\"admin@andersonislandhealth.org\">\n                            <div class=\"row\">\n                                <div hidden=\"hidden\" data-form-alert class=\"alert alert-success col-12\">Thanks for\n                                    filling out the form!</div>\n                                <div hidden=\"hidden\" data-form-alert-danger class=\"alert alert-danger col-12\"> Oops...!\n                                    some problem!\n                                </div>\n                            </div>\n                            <div class=\"dragArea row\">\n                                <div class=\"col-lg-6 col-md-12 col-sm-12 form-group mb-3 mb-3 mb-3 mb-3\" data-for=\"name\">\n                                    <input type=\"text\" name=\"name\" placeholder=\"Name\" data-form-field=\"name\" mbr-theme-style=\"display-7\" class=\"form-control\" value>\n                                </div>\n                                <div class=\"col-lg-6 col-md-12 col-sm-12 form-group mb-3 mb-3 mb-3 mb-3\" data-for=\"email1\">\n                                    <input type=\"email\" name=\"email1\" placeholder=\"Email\" data-form-field=\"email1\" mbr-theme-style=\"display-7\" class=\"form-control\" value>\n                                </div>\n                                <div data-for=\"textarea\" class=\"col-lg-12 col-md-12 col-sm-12 form-group mb-3 mb-3\" style>\n                                    <textarea name=\"textarea\" placeholder=\"Message\" data-form-field=\"textarea\" mbr-theme-style=\"display-7\" class=\"form-control\"></textarea>\n                                </div>\n                                <div class=\"col-md-auto col mbr-section-btn\" mbr-buttons=\"true\" mbr-theme-style=\"display-7\" data-toolbar=\"-mbrBtnMove,-mbrLink,-mbrBtnRemove,-mbrBtnAdd\">\n                                    <a type=\"submit\" class=\"btn btn-primary\" data-app-placeholder=\"Type Text\"><span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                                        Submit\n                                    </a>\n                                </div>\n                            </div>\n                        </form><!--Formbuilder Form-->\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-6 card\">\n                <div class=\"image-wrapper\">\n                    <img src=\"@PROJECT_PATH@/assets/images/img-4795-2.2.jpg-2000x1500.jpg\" alt=\"Mobirise Website Builder\">\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_name": "form01",
          "_sourceTheme": "strengthm5",
          "_cid": "vdXFIH62pX",
          "_anchor": "contact-form-1-vdXFIH62pX",
          "alias": false,
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "~\"calc(@{paddingTop} * 1rem)\"",
            "padding-bottom": "~\"calc(@{paddingBottom} * 1rem)\"",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0"
            },
            ".content-wrapper, .nav-wrapper, .contact-wrapper": {
              "margin-bottom": "2rem",
              "padding": "0 15px"
            },
            ".nav-wrapper": {
              ".list": {
                "padding": "0",
                "list-style": "none",
                ".item-wrap": {
                  "padding": "5px 0",
                  "color": "#006475",
                  "cursor": "pointer",
                  "&:hover": {
                    "opacity": "0.7"
                  }
                }
              }
            },
            ".social-wrap": {
              "display": "flex",
              "gap": "15px",
              "margin-top": "1rem",
              ".soc-item": {
                "width": "36px",
                "height": "36px",
                "background-color": "@socBg",
                "border-radius": "50%",
                "display": "flex",
                "align-items": "center",
                "justify-content": "center",
                ".mbr-iconfont": {
                  "color": "#fff",
                  "font-size": "1rem"
                }
              }
            },
            ".mbr-copy": {
              "border-top": "1px solid rgba(0, 0, 0, 0.1)",
              "padding-top": "1.5rem",
              "color": "#666"
            },
            ".mbr-section-title": {
              "color": "#111"
            },
            ".mbr-section-subtitle, .mbr-nav-title": {
              "color": "#006475"
            }
          },
          "_name": "footer01",
          "_sourceTheme": "strengthm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"footer01 strengthm5\" group=\"Footer\" global once=\"footers\" mbr-class=\"{'mbr-fullscreen': fullScreen, 'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <input type=\"checkbox\" title=\"Navigation\" name=\"showNav\" checked>\n        <input type=\"checkbox\" title=\"Navigation Title\" name=\"showNavTitle\" checked condition=\"showNav\">\n        <input type=\"color\" title=\"Marker Color\" value=\"#ff6d99\" name=\"marker\" condition=\"showNav\" selected>\n        <input type=\"checkbox\" title=\"Copyright\" name=\"showCopy\" checked>\n        <header>Social</header>\n        <input type=\"checkbox\" title=\"Social\" name=\"showSocial\" checked>\n        <input type=\"range\" inline title=\"Social Amount\" name=\"soc\" min=\"1\" max=\"4\" step=\"1\" value=\"4\" condition=\"showSocial\">\n        <input type=\"color\" title=\"Social BG\" value=\"#006475\" name=\"socBg\" condition=\"showSocial\" selected>\n        <input type=\"color\" title=\"Social Border\" value=\"#ffffff\" name=\"socBorder\" condition=\"showSocial\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            \n            <div class=\"col-12 col-md-6 col-lg-4\">\n                <div class=\"content-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\">Anderson Island</h2>\n                    <h3 class=\"mbr-section-subtitle mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showSubtitle\"><b>Healthcare Advocates</b></h3>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">A nonprofit organization established in 2022. Dedicated to accessible, community-led care.</p>\n                </div>\n            </div>\n\n            <div class=\"col-12 col-md-6 col-lg-4\" mbr-if=\"showNav\">\n                <div class=\"nav-wrapper\">\n                    <p class=\"mbr-nav-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showNavTitle\"><b>Quick Links</b></p>\n                    <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-multiline mbr-article>\n                        <li class=\"item-wrap\">Home</li>\n                        <li class=\"item-wrap\">Mission &amp; Vision</li>\n                        <li class=\"item-wrap\">Donate</li><li class=\"item-wrap\">FAQs</li>\n                        <li class=\"item-wrap\">Contact Us</li>\n                    </ul>\n                </div>\n            </div>\n\n            <div class=\"col-12 col-md-12 col-lg-4\">\n                <div class=\"contact-wrapper\">\n                    <p class=\"mbr-nav-title mbr-fonts-style\" mbr-theme-style=\"display-7\"><b>Contact Us</b></p>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\">\n                        info@andersonislandhealth.org<br>\n                        P.O. Box 88973, Steilacoom, WA 98388\n                    </p>\n                    <div class=\"social-wrapper\" mbr-if=\"showSocial\">\n                        <div class=\"social-wrap\">\n                            <div class=\"soc-item\"><span mbr-icon class=\"mbr-iconfont socicon-facebook\"></span></div>\n                            <div class=\"soc-item\" mbr-if=\"soc > 1\"><span mbr-icon class=\"mbr-iconfont socicon-instagram\"></span></div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"row mt-4\" mbr-if=\"showCopy\">\n            <div class=\"col-12 text-center\">\n                <p class=\"mbr-copy mbr-fonts-style\" mbr-theme-style=\"display-7\">\n                    © Copyright 2030 Anderson Island Healthcare Advocates. Website by <a href=\"http://www.aidesigntech.com\" target=\"_blank\">AI Design Tech</a>.\n                </p>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vdYfNhtwhg",
          "_anchor": "footer01-2",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_protectedParams": [],
          "_global": true,
          "_once": "footers",
          "_params": {}
        }
      ]
    }
  }
}