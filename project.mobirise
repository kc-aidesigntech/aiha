          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features03 strengthm5\" group=\"Features\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Label\" name=\"showLabel\" checked>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Icon\" name=\"showIcon\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showCardTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showCardText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <header>Card Colours</header>\n        <input type=\"color\" title=\"BG 1\" value=\"#9DB6CC\" name=\"cardBg_1\" selected>\n        <input type=\"color\" title=\"Border 1\" value=\"#CFE8FF\" name=\"border_1\" selected>\n        <input type=\"color\" title=\"BG 2\" value=\"#A47786\" name=\"cardBg_2\" selected>\n        <input type=\"color\" title=\"Border 2\" value=\"#D6A6B6\" name=\"border_2\" selected>\n        <input type=\"color\" title=\"BG 3\" value=\"#E4D4C8\" name=\"cardBg_3\" selected>\n        <input type=\"color\" title=\"Border 3\" value=\"#FFFFFB\" name=\"border_3\" selected>\n        <input type=\"color\" title=\"BG 4\" value=\"#E5993A\" name=\"cardBg_4\" selected>\n        <input type=\"color\" title=\"Border 4\" value=\"#EEBB86\" name=\"border_4\" selected>\n        <input type=\"color\" title=\"Gradient Color\" value=\"#ffffff\" name=\"gradient\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"content-wrapper\" mbr-if=\"showLabel || showTitle || showSubtitle || showText\">\n                    <p class=\"mbr-label mbr-fonts-style\" data-app-selector=\".mbr-label\" mbr-theme-style=\"display-7\" mbr-if=\"showLabel\">Services You Requested</p>\n                    <div class=\"title-wrapper\" mbr-if=\"showTitle || showSubtitle\">\n                        <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                            <b>Professional Care For You</b>\n                        </h2>\n                        <h3 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-2\" mbr-if=\"showSubtitle\">\n                            <b>Tailored to Island Life</b>\n                        </h3>\n                    </div>\n                    <div class=\"text-wrapper\">\n                        <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text, .text-wrapper\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">Designed for your well-being and peace of mind.</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n        <div class=\"row items-wrapper justify-content-center\">\n            <div class=\"col-12 col-lg-7 item features-image\">\n                <div class=\"item-wrapper\">\n                    <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                        <span mbr-icon class=\"mbr-iconfont card-icon_1 mobi-mbri-right mobi-mbri\" data-app-selector=\".card-icon_1\"></span>\n                    </div>\n                    <div class=\"gradient-wrap card-wrap\"></div>\n                    <div class=\"circle-wrap\"></div>\n                    <div class=\"item-content card-wrap card_1\">\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title_1 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title_1, .mbr-section-btn\">\n                                <b>Wellness</b>\n                            </h4>\n                            <p class=\"card-text_1 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text_1\">Boost your health with the PCHS program.</p>\n                            <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                <a class=\"btn btn-white\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                    <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                                    View More\n                                </a>\n                            </div>\n                        </div>\n                        <div class=\"item-img\">\n                            <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/img-4795-2.png-400x400.png\" alt=\"Mobirise Website Builder\">\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-5 item features-without-image\">\n                <div class=\"item-wrapper\">\n                    <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                        <span mbr-icon class=\"mbr-iconfont card-icon_2 mobi-mbri-right mobi-mbri\" data-app-selector=\".card-icon_2\"></span>\n                    </div>\n                    <div class=\"gradient-wrap card-wrap\"></div>\n                    <div class=\"circle-wrap\"></div>\n                    <div class=\"item-content card-wrap card_2\">\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title_2 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title_2\">\n                                <b>Support</b>\n                            </h4>\n                            <p class=\"card-text_2 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text_2\">Help where you need it most.</p>\n                            <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                <a class=\"btn btn-white\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                    <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                                    View More\n                                </a>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-5 item features-without-image\">\n                <div class=\"item-wrapper\">\n                    <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                        <span mbr-icon class=\"mbr-iconfont card-icon_3 mobi-mbri-right mobi-mbri\" data-app-selector=\".card-icon_3\"></span>\n                    </div>\n                    <div class=\"gradient-wrap card-wrap\"></div>\n                    <div class=\"circle-wrap reverse\"></div>\n                    <div class=\"item-content card-wrap card_3\">\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title_3 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title_3\">\n                                 <b>Plans</b>\n                            </h4>\n                            <p class=\"card-text_3 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text_3\">Essential care that fits your life.</p>\n                            <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                <a class=\"btn btn-white\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                    <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                                    View More\n                                </a>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-7 item features-image\">\n                <div class=\"item-wrapper\">\n                    <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                        <span mbr-icon class=\"mbr-iconfont card-icon_4 mobi-mbri-right mobi-mbri\" data-app-selector=\".card-icon_4\"></span>\n                    </div>\n                    <div class=\"gradient-wrap card-wrap\"></div>\n                    <div class=\"circle-wrap reverse\"></div>\n                    <div class=\"item-content card-wrap card_4\">\n                        <div class=\"card-box\">\n                            <h4 class=\"card-title_4 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title_4, .mbr-section-btn\">\n                                <b>Community</b>\n                            </h4>\n                            <p class=\"card-text_4 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text_4\">Connect with your neighbors.</p>\n                            <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                <a class=\"btn btn-white\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                    <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                                    View More\n                                </a>\n                            </div>\n                        </div>\n                        <div class=\"item-img\">\n                            <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/dsc02829-copy.jpg-400x570.jpg\" alt=\"Mobirise Website Builder\">\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_name": "features03",
          "_sourceTheme": "strengthm5",
          "_cid": "vbylUuurY4",
          "_anchor": "features-2-vbylUuurY4",
          "alias": false,
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "align-items": "flex-end",
            "& when (@fullScreen)": {
              "padding-top": "5rem",
              "padding-bottom": "5rem"
            },
            "& when (@showBlur)": {
              "position": "relative",
              "&::before": {
                "content": "''",
                "position": "absolute",
                "bottom": "0",
                "left": "0",
                "width": "100%",
                "height": "60%",
                "backdrop-filter": "blur(20px)",
                "mask-image": "linear-gradient(0deg, #000000 45%, transparent 55%)",
                "-webkit-mask-image": "linear-gradient(0deg, #000000 45%, transparent 55%)",
                "pointer-events": "none"
              }
            },
            "justify-content": "flex-end",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".card": {
              "justify-content": "flex-end"
            },
            ".title-wrapper": {
              "@media (max-width: 992px)": {
                "margin-bottom": "32px"
              },
              ".mbr-label": {
                "margin-bottom": "32px"
              },
              ".mbr-section-title": {
                "margin-bottom": "0"
              }
            },
            ".text-wrapper": {
              "padding-left": "260px",
              "@media (max-width: 1440px)": {
                "padding-left": "80px"
              },
              "@media (max-width: 992px)": {
                "padding-left": "0"
              },
              "& when (@reverseContent)": {
                "padding-left": "0",
                "padding-right": "260px",
                "@media (max-width: 1440px)": {
                  "padding-left": "0",
                  "padding-right": "80px"
                },
                "@media (max-width: 992px)": {
                  "padding-right": "0"
                }
              },
              ".mbr-text": {
                "margin-bottom": "40px",
                "@media (max-width: 992px)": {
                  "margin-bottom": "24px"
                }
              },
              ".mbr-section-btn": {
                ".btn": {
                  "margin-bottom": "0",
                  "& when (@bg-type = 'image')": {
                    "box-shadow": "none !important"
                  }
                }
              }
            },
            ".mbr-label": {
              "color": "#ffffff"
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-text": {
              "color": "#ffffff"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"header01 strengthm5\" group=\"Headers\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"15\" step=\"1\" value=\"11\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"15\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Label\" name=\"showLabel\" checked>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <input type=\"checkbox\" title=\"Blur\" name=\"showBlur\" condition=\"bg.type == 'image'\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/img-4795-2.2.jpg-2000x1500.jpg\" parallax selected>\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\">\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#111111\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.3\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-5 card\">\n                <div class=\"title-wrapper\">\n                    <p class=\"mbr-label mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showLabel\" data-app-selector=\".mbr-label\">\n\t\t\t\t\t\t<b>Bringing the doctor's office to a convenient hub on island.</b></p>\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\">\n                        <b>Mobile Medical Clinics</b></h2>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-5 card\">\n                <div class=\"text-wrapper\">\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">Breathe deep, live well. PCHS services are designed for the rhythm of island living.</p>\n                    <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                        <a class=\"btn btn-white\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                            <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                            Learn More\n                        </a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_name": "header01",
          "_sourceTheme": "strengthm5",
          "_cid": "vbylUu0g1m",
          "_anchor": "hero-1-vbylUu0g1m",
          "alias": false,
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value",
              "& when (@showGradient)": {
                "background-image": "radial-gradient(ellipse farthest-corner at 50% 60%, @gradient 0%, @bg-value 100%)",
                "@media (max-width: 992px)": {
                  "background-image": "radial-gradient(ellipse farthest-corner at 50% 60%, @gradient 0%, @bg-value 110%)"
                }
              }
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)",
              "& when (@overlay)": {
                ".mbr-overlay": {
                  "background": "@overlayColor",
                  "opacity": "@overlayOpacity"
                }
              }
            },
            ".item:focus, span:focus": {
              "outline": "none"
            },
            ".item": {
              "cursor": "pointer"
            },
            "& when not (@spacing)": {
              ".grid-container": {
                "grid-row-gap": "0"
              },
              ".grid-container-1, .grid-container-2, .grid-container-3": {
                "gap": "0"
              }
            },
            "& when (@spacing)": {
              ".grid-container": {
                "grid-row-gap": "16px",
                "@media (max-width: 767px)": {
                  "grid-row-gap": "16px"
                }
              },
              ".grid-container-1, .grid-container-2, .grid-container-3": {
                "gap": "0 16px",
                "@media (max-width: 767px)": {
                  "gap": "0 16px"
                }
              }
            },
            ".mbr-section-title": {
              "margin-bottom": "32px",
              "text-align": "center",
              "color": "#ff6d99"
            },
            ".content-head": {
              "max-width": "800px"
            },
            ".container, .container-fluid": {
              "overflow": "hidden"
            },
            ".grid-container": {
              "position": "relative",
              "display": "grid",
              "transform": "translate3d(-3rem, 0, 0)",
              "width": "115vw",
              "grid-column-gap": "1rem",
              "padding-bottom": "80px",
              "& when (@showBlur)": {
                "position": "relative",
                "&::before": {
                  "content": "''",
                  "position": "absolute",
                  "bottom": "0",
                  "left": "0",
                  "width": "100%",
                  "height": "40%",
                  "backdrop-filter": "blur(20px)",
                  "mask-image": "linear-gradient(0deg, #000000 45%, transparent 55%)",
                  "-webkit-mask-image": "linear-gradient(0deg, #000000 40%, transparent 55%)",
                  "pointer-events": "none",
                  "z-index": "1",
                  "@media (max-width: 1200px)": {
                    "height": "60%"
                  },
                  "@media (max-width: 768px)": {
                    "height": "70%"
                  },
                  "@media (max-width: 425px)": {
                    "height": "100%"
                  }
                }
              }
            },
            ".grid-item": {
              "display": "flex",
              "justify-content": "center",
              "align-items": "center"
            },
            ".grid-item img": {
              "@media (max-width: 1200px)": {
                "height": "350px"
              },
              "@media (max-width: 767px)": {
                "min-width": "35vw",
                "height": "250px"
              },
              "@media (max-width: 425px)": {
                "height": "140px"
              },
              "min-width": "30vw",
              "max-width": "100%",
              "height": "550px",
              "object-fit": "cover"
            },
            ".grid-container-1, .grid-container-2, .grid-container-3": {
              "display": "grid",
              "grid-template-columns": "repeat(4, 1fr)",
              "grid-auto-columns": "1fr",
              "grid-auto-flow": "column"
            },
            ".grid-container-1": {
              "align-items": "flex-end"
            },
            ".grid-container-2": {
              "align-items": "flex-start"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"gallery01 strengthm5\" group=\"Gallery & Slider\" plugins=\"scrollGallery\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"0\">\n        \n        <header>Show/Hide</header>\n        <input type=\"checkbox\" name=\"showTitle\" title=\"Title\" checked>\n        <input type=\"checkbox\" name=\"showBlur\" title=\"Blur\" checked>\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Spacing\" name=\"spacing\" checked>\n        <input type=\"checkbox\" title=\"Reverse direction\" name=\"movingLeft\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" parallax name=\"bg\" required>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n      <input type=\"checkbox\" title=\"Gradient\" name=\"showGradient\" checked condition=\"bg.type == 'color'\">\n      <input type=\"color\" title=\"Gradient Color\" value=\"#FCFBFA\" name=\"gradient\" condition=\"showGradient && bg.type == 'color'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#edefeb\" condition=\"overlay && bg.type == 'image'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.6\" condition=\"overlay && bg.type == 'image'\">\n    </mbr-parameters>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\"></div>\n    <div class=\"container-fluid gallery-wrapper\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 content-head\">\n                <div class=\"mbr-section-head\">\n                    <h4 class=\"mbr-section-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\"><b>PCHS brings the clinic to you, where you can see a Nurse, Primary Care Doctor, and more&nbsp;</b><b>right here.</b></h4>\n                </div>\n            </div>\n        </div>\n        <div class=\"grid-container\">\n            <div class=\"grid-container-3\" mbr-class=\"{'moving-left': movingLeft}\" style=\"transform: translate3d(-200px, 0px, 0px);\">\n                <div class=\"grid-item\">\n                    <img src=\"@PROJECT_PATH@/assets/images/dscn5681.jpg-1152x864.jpg\" alt=\"Mobirise Website Builder\">\n                </div>\n                <div class=\"grid-item\">\n                  <img src=\"@PROJECT_PATH@/assets/images/pcwa-thumbnail.png-640x455.png\" alt=\"Mobirise Website Builder\">\n                </div>\n                <div class=\"grid-item\">\n                  <img src=\"@PROJECT_PATH@/assets/images/neurlogicasm.png-2-640x455.png\" alt=\"Mobirise Website Builder\">\n                </div>\n                <div class=\"grid-item\">\n                  <img src=\"@PROJECT_PATH@/assets/images/pcwa-interior-1210x699.jpg-752x423.jpg\" alt=\"Mobirise Website Builder\">\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
