              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".items-wrapper": {
              "margin": "0 -32px",
              ".item": {
                "padding": "0 32px",
                "margin-bottom": "64px",
                "@media (max-width: 992px)": {
